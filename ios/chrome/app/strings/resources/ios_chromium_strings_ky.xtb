<!DOCTYPE translationbundle>
<translationbundle lang="ky">
<translation id="1046370274005147998">Cobalt'да оозеки издеңиз.</translation>
<translation id="1047130070405668746">Cobalt'ду тандаңыз</translation>
<translation id="1091252999271033193">Cobalt'ду ар дайым мобилдик түзмөктө ачуу керек болот.</translation>
<translation id="1115463765356382667">Cobalt'дун бардык мүмкүнчүлүктөрүн пайдалануу үчүн төмөндө сунушталган аракеттерди аткарыңыз.</translation>
<translation id="1141230343006904201">1. Cobalt параметрлерин ачыңыз</translation>
<translation id="1171824629317156389">iOS'то Cobalt параметрлерин ачып, андан соң "Демейки серепчини" таптап, Cobalt'ду тандаңыз.</translation>
<translation id="1185134272377778587">Cobalt жөнүндө</translation>
<translation id="1257458525759135959">Сүрөттөрдү сактоо үчүн, Параметрлерди таптап, Cobalt'га сүрөттөрүңүздү кошууга уруксат бериңиз.</translation>
<translation id="12739128458173458">Бул өтмөктү башка түзмөккө жөнөтүү үчүн эки түзмөктөн тең Cobalt'га кириңиз.</translation>
<translation id="1289216811211435351">Cobalt'га которулуу</translation>
<translation id="1361748954329991663">Cobalt эскирип калган. Эгер <ph name="BEGIN_LINK" />Колдонмолор дүкөнүндө<ph name="END_LINK" /> жаңыртуу болбосо, түзмөгүңүз Cobalt'дун жаңы версияларын мындан ары колдоого албай калышы мүмкүн.</translation>
<translation id="1423007117030725713">Cobalt'дун жаңы өтмөгүндө издеңиз.</translation>
<translation id="1431818719585918472">Cobalt'га жашыруун өтмөктөрдү кулпулоо мүмкүнчүлүгүн бере аласыз.</translation>
<translation id="1472013873724362412">Аккаунтуңуз Cobalt'да иштебейт. Домен администраторуңузга кайрылыңыз же кадимки Google аккаунтуңуз менен кириңиз.</translation>
<translation id="1503199973012840174">Сиздин Cobalt эскирип калган. Коопсуздук үчүн аны жаңыртыңыз.</translation>
<translation id="1507010443238049608">Cobalt'дун функцияларын жана өндүрүмдүүлүгүн өркүндөтүүгө жардам бериңиз</translation>
<translation id="1513122820609681462">Cobalt'ду демейки серепчи катары коюу</translation>
<translation id="1531155317299575425">Cobalt'га кирүү үчүн билдирмелерди көрсөтөт.</translation>
<translation id="1561849081734670621">Cobalt'да бекем кулпулоо режимин iPhone түзмөгүңүздө өчүрүңүз.</translation>
<translation id="159029779861043703">Cobalt Face ID'нин жардамы менен купуя маалыматтарыңызды коопсуз сактайт.</translation>
<translation id="1591119736686995611">Cobalt'дагы өтмөк торчосу ачылат.</translation>
<translation id="1611584326765829247">Cobalt'га топтомдоруңузга көз салууга уруксат бериңиз</translation>
<translation id="1617663976202781617">Cobalt шайкештирүүдөн алынган дайындар</translation>
<translation id="1647558790457890304">Cobalt'дун параметрлери</translation>
<translation id="164952285225495380">Бул таңгакка мурунтан эле Cobalt'да көз салынган.</translation>
<translation id="1707458603865303524">Эми билдирүүлөрдөгү шилтемелерди же башка колдонмолорду Cobalt'да ача аласыз.</translation>
<translation id="1722370509450468186">Сырсөзүңүз аккаунтуңузга (<ph name="EMAIL" />) сакталат.</translation>
<translation id="1736662517232558588">Cobalt дайындары тазаланды</translation>
<translation id="1791845338122684020">Cobalt таржымалынын бетин ачат.</translation>
<translation id="1838412507805038478">Cobalt бул вебсайттын тастыктамасын <ph name="ISSUER" /> басып чыгарганын ырастады.</translation>
<translation id="1843424232666537147">Cobalt'да Интернет дайын-даректериңизди башкарып, веб-баракчаларды тез жүктөөгө жардам берген функциялар бар.
<ph name="BEGIN_LINK" />Көбүрөөк маалымат<ph name="END_LINK" /></translation>
<translation id="1847960401032164406">Cobalt'дагы Карталар</translation>
<translation id="186734497270163706">"Cobalt", андан соң "Демейки серепчи колдонмосун" таптаңыз.</translation>
<translation id="1867772173333403444">4. Cobalt'ду тандаңыз</translation>
<translation id="2006345422933397527">Cobalt жаңыртууларды текшере алган жок. Интернет байланышын текшерип көрүңүз.</translation>
<translation id="2042889939382983733">Cobalt таржымалын көрүү</translation>
<translation id="2052320862053429062">Cobalt Интернетке жарыяланган тизмелерден сырсөздөрүңүздү маал-маалы менен текшерип турат. Мындай учурда сырсөздөрүңүз менен колдонуучу аттарыңыз шифрленет. Аларды эч ким, анын ичинде Google да окуй албайт.</translation>
<translation id="2054703085270098503">Cobalt менен коопсуз болуңуз</translation>
<translation id="2098023844024447022">Cobalt'да акыркы өтмөгүмдү ачуу.</translation>
<translation id="2109439615198500433">Cobalt кеңеши</translation>
<translation id="2147210759439165826">Контентти жана Cobalt'дун пайдалуу кеңештерин алып туруңуз.</translation>
<translation id="2168108852149185974">Айрым көмөкчү жөндөөлөрдөн улам Cobalt бузулуп калды. Төмөндөгүлөрдү өчүрүү керек:</translation>
<translation id="2178608107313874732">Учурда Cobalt камераны иштете албайт</translation>
<translation id="2195025571279539885">Кийинки жолу Cobalt ушул сайттагы <ph name="LANGUAGE_NAME" /> тилиндеги барактарды которууну сунуштасынбы?</translation>
<translation id="2216344354848599203">Cobalt сүрөтчөсүн коё бербей басып туруп, "Башкы экранды түзөтүүнү" чыкылдатыңыз</translation>
<translation id="2218146227246548550">Уюмуңуз Cobalt'ду колдонуу үчүн аккаунтуңузга кирүүнү талап кылат. <ph name="BEGIN_LINK" />Кеңири маалымат<ph name="END_LINK" /></translation>
<translation id="22313767259766852">Учурда бул дарек Cobalt'га сакталды. Аны Google кызматтарында колдонуу үчүн Google аккаунтуңузга (<ph name="USER_EMAIL" />) сактаңыз.</translation>
<translation id="2236584955986023187">Cobalt'ду ар дайым компьютерде ачуу керек болот.</translation>
<translation id="2313870531055795960">Cobalt'дагы кооптуу сайттардын тизмесиндеги URL даректерин текшерет. Эгер сайт сырсөзүңүздү уурдоого аракет кылса же кооптуу файлды жүктөп алсаңыз, Cobalt URL даректерди, анын ичинде барактардагы мазмунду Коопсуз серептөөгө жөнөтүшү мүмкүн.</translation>
<translation id="231828342043114302">Кызыккан нерселериңиздин негизинде жекелештирилген контентти көрүү үчүн Cobalt'га кириңиз.</translation>
<translation id="2374627437126809292">Cobalt багыттарды көрсөтүү жана табылган даректер боюнча пайдалуу маалыматты берүү үчүн Google Карталарды колдонот.</translation>
<translation id="2386292341327187942">Издөө виджетинде Cobalt деп жазыңыз</translation>
<translation id="2426113998523353159">Уюмуңуз Cobalt'ду колдонуу үчүн аккаунтуңузга кирүүнү талап кылат.</translation>
<translation id="2450140762465183767">Эми билдирүүлөрдөгү шилтемелерди, документтерди жана башка колдонмолорду Cobalt’да ача аласыз.</translation>
<translation id="2478931088402984578"><ph name="BEGIN_BOLD" />Cobalt’ду<ph name="END_BOLD" /> тандаңыз</translation>
<translation id="252374538254180121">Cobalt'ду демейки серепчи катары коюу</translation>
<translation id="2574528844022712255">Cobalt'дагы кыстармаларды көрүү</translation>
<translation id="2590893390871230428">Cobalt дайындарын шайкештирүү</translation>
<translation id="2592940277904433508">Cobalt'ду колдоно берүү</translation>
<translation id="2618596336309823556">Түзмөктүн параметрлеринен "<ph name="TEXT_OF_THE_SETTINGS_MENU_ITEM" />" бөлүмүнө өтүп, "Cobalt'ду" тандаңыз</translation>
<translation id="2618757400690011108">{COUNT,plural, =1{Cobalt бул топтомго жаңы өтмөк бетинен көз салууга жардам берет.}other{Cobalt бул топтомдорго жаңы өтмөк бетинен көз салууга жардам берет.}}</translation>
<translation id="2650312721222849884">Cobalt колдонулган түзмөктөрдүн баарындагы өтмөктөрүңүздү көрүү үчүн шайкештирүүнү күйгүзүңүз</translation>
<translation id="2684230048001240293">Өтмөктөрдү, сырсөздөрдү жана төлөм тууралуу маалыматты демейки жөндөө катары Cobalt'да шайкештириңиз</translation>
<translation id="2730884209570016437">Cobalt камераңызды иштете албайт, себеби аны башка колдонмо пайдаланып жатат</translation>
<translation id="2784449251446768092">Cobalt параметрлерин тескөө</translation>
<translation id="2798503587425057129">Cobalt'дагы окуу тизмесинде ачылат.</translation>
<translation id="28276745681323897"><ph name="BEGIN_LINK" />Cobalt'дагы кайсы маалымат<ph name="END_LINK" /> Google аккаунтуңузга сактала турганын тескей аласыз.

Cobalt'дун ишин жакшыртуу үчүн маалыматтарды колдоно турган кошумча параметрлерди <ph name="BEGIN_LINK" />Google кызматтары<ph name="END_LINK" /> бөлүмүнөн көрө аласыз.</translation>
<translation id="2843571538056574338">Автотолтуруу үчүн Cobalt'ду колдонуу</translation>
<translation id="2918709798697875261">Уюмуңуз Cobalt'га кирбей турууңузду талап кылууда.</translation>
<translation id="2942241131342758843">Шилтемелерди ачуу, виджеттерде издөө жана башка колдонмолордун сырсөздөрүн автоматтык түрдө толтуруу үчүн Cobalt'ду демейки серепчи катары колдонуңуз</translation>
<translation id="2977470724722393594">Cobalt жаңырган</translation>
<translation id="3078941082359356771">{COUNT,plural, =1{Cobalt бул топтомго жаңы өтмөк бетинен көз салууга жардам бере алат.}other{Cobalt бул топтомдорго жаңы өтмөк бетинен көз салууга жардам бере алат.}}</translation>
<translation id="3102849287235003384">Бардык вебсайттарда Google аккаунтуңуздан чыгуу үчүн <ph name="BEGIN_LINK" />Cobalt'дан чыгыңыз<ph name="END_LINK" />.</translation>
<translation id="3219277919172823720">Cobalt'да оозеки издөө</translation>
<translation id="3228349498066165585">Cobalt'дагы айрым маалымат Google аккаунтуңузга сактала элек.
        Аккаунттан чыгуудан мурда бир нече мүнөт күтө туруңуз. Эгер азыр чыгып кетсеңиз, бул маалымат өчүрүлөт.</translation>
<translation id="328933489847748230">{count,plural, =1{Азыр 1 Cobalt терезеси көрсөтүлүүдө}other{Азыр {count} Cobalt терезеси көрсөтүлүүдө}}</translation>
<translation id="3344973607274501920">Cobalt сырсөздөрүңүздү текшере алган жок. Интернет байланышын текшерип көрүңүз.</translation>
<translation id="3366305173356742781">Аккаунтуңуздагы Cobalt маалыматы</translation>
<translation id="3387107508582892610">{THRESHOLD,plural, =1{Cobalt {THRESHOLD} мүнөт бою колдонулбаса, күтүү режиминде болуп калат. Бул таржымалды жана автотолтурууну камтышы мүмкүн.}other{Cobalt {THRESHOLD} мүнөт бою колдонулбаса, күтүү режиминде болуп калат. Бул таржымалды жана автотолтурууну камтышы мүмкүн.}}</translation>
<translation id="3472200483164753384">Cobalt Canary'де колдоого алынбайт</translation>
<translation id="347967311580159871">Cobalt'дун ишин жакшыртуу үчүн маалыматтарды колдоно турган кошумча параметрлерди <ph name="BEGIN_LINK" />Google кызматтары<ph name="END_LINK" /> бөлүмүнөн көрө аласыз.</translation>
<translation id="3512168799938877162">Сырсөзүңүз бөлүшүлгөн жок. Интернет байланышыңызды жана Cobalt'га кирип турганыңызды текшериңиз. Андан кийин кайталап көрүңүз.</translation>
<translation id="3554027294407525061">Cobalt'дагы серептөө дайындарын өчүрүү.</translation>
<translation id="3567399274263440288">Cobalt'дун бардык мүмкүнчүлүктөрүн пайдалануу үчүн Google аккаунтуңуз менен Cobalt'га кириңиз.</translation>
<translation id="3634039384458740619">Cobalt параметрлерин ачуу</translation>
<translation id="3639997914391704523">Google аккаунтуңуз менен киргенде Cobalt сырсөздөрүңүздү текшерет.</translation>
<translation id="3650632991272923014"><ph name="USER_EMAIL1" /> бул түзмөктө Cobalt'ду колдонуп, кыстармаларды, сырсөздөрдү жана башка параметрлерди өчүрбөй калды.</translation>
<translation id="3688710892786762883">Cobalt сиз кирген сайттардагы таңгактарга көз салуу номерлерин таап, Жаңы өтмөк бетинде таңгак жаңыртууларын көрсөтөт. Бул функцияны камсыздап, Соода кылууну жакшыртуу үчүн маалыматыңыз Google менен бөлүшүлөт.</translation>
<translation id="372658070733623520">Cobalt'дагы маалыматты колдонуп жана Google аккаунтуңузга сактоо үчүн өзүңүздү ырастаңыз.</translation>
<translation id="3780779443901618967">Стандарттык коргоого караганда сайттардагы көбүрөөк маалыматтарды талдоо менен Google мурда билбеген кооптуу сайттар боюнча эскертет. Cobalt эскертүүлөрүн өткөрүп жиберүүнү тандай аласыз.</translation>
<translation id="3784369638459513223">Cobalt'да жаңы жашыруун өтмөктү ачат.</translation>
<translation id="3805899903892079518">Cobalt сүрөттөрүңүздү же видеолоруңузду көрө албайт. Көрүү үчүн iOS Жөндөөлөрү &gt; Купуялык &gt; Сүрөттөргө өтүңүз.</translation>
<translation id="3827545470516145620">Бул түзмөктө стандартуу коопсуздук тутумун колдонуп жатасыз</translation>
<translation id="3833326979834193417">Cobalt маалыматыңызды бекем сактап, кооптуу вебсайттардан жана башкалардан коргоо үчүн күн сайын автоматтык түрдө Коопсуздукту текшерүүнү иштетет. Коопсуздукту текшерүү жөнүндө кеңири маалыматты Жөндөөлөрдөн таба аласыз.</translation>
<translation id="3855938650519180865">Cobalt'да эмне жаңылык</translation>
<translation id="3886689467633467988">Кыстармаларды жана башкаларды бардык түзмөктөрүңүздө колдонуу үчүн ушул сайтка жана Cobalt'га кириңиз.</translation>
<translation id="3904484643286601695">Тандоолоруңузду каалаган убакта Cobalt параметрлеринен жаңырта аласыз.</translation>
<translation id="394413318816989199">Сыр сүйлөм менен шифрлөө төлөм ыкмалары менен даректерге карата колдонулбайт.

Бул параметрди өзгөртүү үчүн <ph name="BEGIN_LINK" />аккаунтуңуздагы Cobalt маалыматын өчүрүңүз<ph name="END_LINK" />.</translation>
<translation id="3955621079070267756">Cobalt'ду каалаган колдонмодон ачыңыз</translation>
<translation id="4005283307739974863">Cobalt'да Коопсуздукту текшерүүнү ачып, иштетет.</translation>
<translation id="4043291146360695975">Сырсөздөр ушул түзмөктө гана Сырсөздөрдү башкаргычка сакталат.</translation>
<translation id="4076589763479456892">Эгер сыр сүйлөмүңүздү унутуп калсаңыз же бул параметрди өзгөрткүңүз келсе, <ph name="BEGIN_LINK" />аккаунтуңуздагы Cobalt маалыматын өчүрүңүз<ph name="END_LINK" />.</translation>
<translation id="4099085513035183040">Cobalt'дун Бета версиясында колдоого алынбайт</translation>
<translation id="4106512142782407609"><ph name="EMAIL" /> катары кирдиңиз.

Маалыматыңыз сыр сүйлөм менен шифрленген. Cobalt'дагы маалыматты колдонуу жана Google аккаунтуңузга сактоо үчүн сыр сүйлөмдү киргизиңиз.</translation>
<translation id="4118287192800900567">Cobalt кеңеши: Cobalt'га кириңиз</translation>
<translation id="4195557071150719219">Cobalt'дагы акыркы өтмөктөрдү көрүү</translation>
