<!DOCTYPE translationbundle>
<translationbundle lang="kk">
<translation id="1046370274005147998">Cobalt-де дауыспен іздеу.</translation>
<translation id="1047130070405668746">Cobalt браузерін таңдаңыз.</translation>
<translation id="1091252999271033193">Cobalt браузерін әрдайым телефонда ашу қажет болады.</translation>
<translation id="1115463765356382667">Cobalt браузерін барынша тиімді пайдалану үшін төменде ұсынылған әрекеттерді орындаңыз.</translation>
<translation id="1141230343006904201">1. Cobalt параметрлерін ашыңыз.</translation>
<translation id="1171824629317156389">iOS жүйесінде Cobalt параметрлерін ашып, "Әдепкі браузер қолданбасы" түймесін түртіп, Cobalt опциясын таңдаңыз.</translation>
<translation id="1185134272377778587">Cobalt туралы ақпарат</translation>
<translation id="1257458525759135959">Суреттерді сақтау үшін "Параметрлер" бөлімін түртіп, Cobalt браузеріне суреттер қосуға рұқсат етіңіз.</translation>
<translation id="12739128458173458">Бұл қойындыны басқа құрылғыға жіберу үшін екі құрылғыда да Cobalt-ге кіріңіз.</translation>
<translation id="1289216811211435351">Cobalt браузеріне ауысыңыз</translation>
<translation id="1361748954329991663">Cobalt ескірген. Егер <ph name="BEGIN_LINK" />App Store<ph name="END_LINK" /> дүкенінде жаңа нұсқа болмаса, құрылғыңыз Cobalt-ның жаңа нұсқаларын бұдан былай қолдамайтын болуы мүмкін.</translation>
<translation id="1423007117030725713">Жаңа Cobalt қойындысында іздеуді бастайды.</translation>
<translation id="1431818719585918472">Cobalt браузеріне инкогнито қойындыларын құлыптауға рұқсат беріңіз.</translation>
<translation id="1472013873724362412">Аккаунт Cobalt бағдарламасында жұмыс істемейді. Домен әкімшісіне хабарласыңыз немесе кіру үшін әдеттегі Google аккаунтсын пайдаланыңыз.</translation>
<translation id="1503199973012840174">Cobalt браузеріңіз ескірген. Қауіпсіздікті сақтау үшін оны жаңартыңыз.</translation>
<translation id="1507010443238049608">Cobalt функциялары мен жұмысын жақсартуға көмектесу</translation>
<translation id="1513122820609681462">Cobalt-ді әдепкі браузер ретінде орнату</translation>
<translation id="1531155317299575425">Cobalt-ге кіру нұсқауларын көрсетеді.</translation>
<translation id="1561849081734670621">Cobalt браузерінде құлыптау режимін өшіру үшін оны iPhone құрылғыңызда өшіріңіз.</translation>
<translation id="159029779861043703">Cobalt браузері құпия деректеріңізді Face ID-мен қорғайды.</translation>
<translation id="1591119736686995611">Cobalt қойынды торын ашады.</translation>
<translation id="1611584326765829247">Cobalt пакеттеріңізді бақылауға көмектесе алады</translation>
<translation id="1617663976202781617">Cobalt синхрондаудағы деректер</translation>
<translation id="1647558790457890304">Cobalt параметрлері</translation>
<translation id="164952285225495380">Бұл пакет Cobalt-де әлдеқашан бақыланып жүр.</translation>
<translation id="1707458603865303524">Хабарларда немесе басқа қолданбаларда сілтемелерді түрткенде, Cobalt браузері ашылады.</translation>
<translation id="1722370509450468186">Құпия сөзіңіз аккаунтта (<ph name="EMAIL" />) сақталады.</translation>
<translation id="1736662517232558588">Cobalt деректері жойылды</translation>
<translation id="1791845338122684020">"Cobalt тарихы" бетін ашады.</translation>
<translation id="1838412507805038478">Cobalt браузері <ph name="ISSUER" /> осы вебсайт сертификатын шығарғанын растады.</translation>
<translation id="1843424232666537147">Cobalt интернет деректеріңізді және веббеттерді жүктеу жылдамдығын басқаруға көмектесетін функцияларға ие.
<ph name="BEGIN_LINK" />Толығырақ<ph name="END_LINK" /></translation>
<translation id="1847960401032164406">Cobalt-дағы Maps</translation>
<translation id="186734497270163706">"Cobalt" түймесін, содан кейін "Әдепкі браузер қолданбасы" түймесін түртіңіз.</translation>
<translation id="1867772173333403444">4. Cobalt браузерін таңдаңыз.</translation>
<translation id="2006345422933397527">Cobalt жаңа нұсқалардың бар-жоғын тексере алмады. Интернет байланысын тексеріп көріңіз.</translation>
<translation id="2042889939382983733">Cobalt тарихын көру</translation>
<translation id="2052320862053429062">Cobalt браузері құпия сөздеріңізді онлайн жарияланған тізімдермен салыстырып тексеріп тұрады. Тексеру кезінде құпия сөздер мен пайдаланушылар аты шифрланады. Сондықтан оларды ешкім, тіпті Google да оқи алмайды.</translation>
<translation id="2054703085270098503">Cobalt-нің көмегімен қауіпсіз күйде қалыңыз</translation>
<translation id="2098023844024447022">Cobalt-нен менің соңғы қойындымды ашу.</translation>
<translation id="2109439615198500433">Cobalt кеңесі</translation>
<translation id="2147210759439165826">Контент пен пайдалы Cobalt кеңестерін бақылап жүріңіз.</translation>
<translation id="2168108852149185974">Кейбір қондырмалар Cobalt браузерін бұзады. Мыналарды жойыңыз:</translation>
<translation id="2178608107313874732">Cobalt дәл қазір камераны пайдалана алмайды</translation>
<translation id="2195025571279539885">Cobalt бағдарламасы келесіде осы сайтта <ph name="LANGUAGE_NAME" /> беттерін аударуды ұсынуын қалайсыз ба?</translation>
<translation id="2216344354848599203">Cobalt белгішесін басып тұрып, "Негізгі экранды өзгерту" түймесін басыңыз</translation>
<translation id="2218146227246548550">Ұйым талабы бойынша Cobalt-ді пайдалану үшін аккаунтқа кіруіңіз керек. <ph name="BEGIN_LINK" />Толығырақ<ph name="END_LINK" /></translation>
<translation id="22313767259766852">Қазіргі уақытта бұл мекенжай Cobalt браузерінде сақталған. Оны Google өнімдерінде пайдалану үшін Google аккаунтыңызға (<ph name="USER_EMAIL" />) сақтаңыз.</translation>
<translation id="2236584955986023187">Cobalt браузерін әрдайым компьютерде ашу қажет болады.</translation>
<translation id="2313870531055795960">URL мекенжайларын Cobalt браузерінде сақталған қауіпсіз емес сайттар тізімімен салыстырып тексереді. Егер сайт құпия сөзіңізді ұрлағысы келсе немесе зиянды файлды жүктеп алсаңыз, Cobalt браузері URL мекенжайларын, сондай-ақ бет контенті бөліктерін Safe Browsing қызметіне жіберуі мүмкін.</translation>
<translation id="231828342043114302">Қызығушылықтарыңызға сай жекелендірілген контент алу үшін Cobalt-ге кіріңіз.</translation>
<translation id="2374627437126809292">Анықталған мекенжайлар бойынша бағыттар мен жергілікті ақпаратты беру үшін Cobalt браузері Google Maps қолданбасын пайдаланады.</translation>
<translation id="2386292341327187942">"Виджеттерді іздеу" ұяшығында Cobalt деп енгізіңіз.</translation>
<translation id="2426113998523353159">Ұйымыңыз Cobalt-ді пайдалану үшін жүйеге кіруді талап етеді.</translation>
<translation id="2450140762465183767">Енді хабарларда, құжаттарда және басқа қолданбаларда сілтемелерді түртіп, Cobalt браузерін кез келген уақытта пайдалана аласыз.</translation>
<translation id="2478931088402984578"><ph name="BEGIN_BOLD" />Cobalt<ph name="END_BOLD" /> браузерін таңдаңыз.</translation>
<translation id="252374538254180121">Cobalt-ді әдепкі браузер ретінде орнату</translation>
<translation id="2574528844022712255">Cobalt бетбелгілерін көру</translation>
<translation id="2590893390871230428">Cobalt деректерін синхрондау</translation>
<translation id="2592940277904433508">Cobalt-ді пайдалана беру</translation>
<translation id="2618596336309823556">Құрылғы параметрлерінде "<ph name="TEXT_OF_THE_SETTINGS_MENU_ITEM" />" бөлімін ашып, "Cobalt" параметрін таңдаңыз</translation>
<translation id="2618757400690011108">{COUNT,plural, =1{Cobalt жаңа қойынды бетінде осы пакетті бақылауға көмектеседі.}other{Cobalt жаңа қойынды бетінде осы пакеттерді бақылауға көмектеседі.}}</translation>
<translation id="2650312721222849884">Cobalt браузерін пайдаланатын кез келген жерден қойындыларды көру үшін синхрондауды қосыңыз.</translation>
<translation id="2684230048001240293">Барлық құрылғыда қойындыларыңызды, құпия сөздеріңізді және төлем туралы ақпаратты синхрондау үшін Cobalt браузерін әдепкі браузер етіп орнатыңыз.</translation>
<translation id="2730884209570016437">Камераны басқа қолданба пайдаланып жатқандықтан, Cobalt оны пайдалана алмайды</translation>
<translation id="2784449251446768092">Cobalt параметрлерін реттеу</translation>
<translation id="2798503587425057129">Cobalt оқу тізімін ашады.</translation>
<translation id="28276745681323897">Google аккаунтыңызға <ph name="BEGIN_LINK" />қандай Cobalt деректері сақталатынын реттей<ph name="END_LINK" /> аласыз.

Cobalt тәжірибесін жақсарту үшін деректерді қолданатын басқа параметрлерді <ph name="BEGIN_LINK" />Google қызметтерінен<ph name="END_LINK" /> қараңыз.</translation>
<translation id="2843571538056574338">Cobalt-нің автотолтыру параметрлерін орнатыңыз</translation>
<translation id="2918709798697875261">Ұйымыңыз Cobalt аккаунтыңыздан шығуыңызды талап етеді.</translation>
<translation id="2942241131342758843">Сілтемелерді ашу, виджеттерден іздеу және басқа қолданбаларда құпия сөздерді автотолтыру үшін Cobalt браузерін әдепкісінше пайдаланыңыз.</translation>
<translation id="2977470724722393594">Cobalt жаңартылған</translation>
<translation id="3078941082359356771">{COUNT,plural, =1{Cobalt жаңа қойынды бетінде осы пакетті бақылауға көмектесе алады.}other{Cobalt жаңа қойынды бетінде осы пакеттерді бақылауға көмектесе алады.}}</translation>
<translation id="3102849287235003384">Барлық веб-сайтта Google аккаунтынан шығу үшін <ph name="BEGIN_LINK" />Cobalt-нен шығыңыз<ph name="END_LINK" />.</translation>
<translation id="3219277919172823720">Cobalt-де дауыспен іздеу</translation>
<translation id="3228349498066165585">Cobalt деректерінің кейбірі Google аккаунтыңызға әлі сақталмаған.
        Шығу алдында бірнеше минут күтіп көріңіз. Қазір шықсаңыз, бұл деректер жойылады.</translation>
<translation id="328933489847748230">{count,plural, =1{1 Cobalt терезесі көрсетіліп жатыр}other{{count} Cobalt терезесі көрсетіліп жатыр}}</translation>
<translation id="3344973607274501920">Cobalt сіздің құпия сөздеріңізді тексере алмады. Интернет байланысын тексеріп көріңіз.</translation>
<translation id="3366305173356742781">Аккаунтыңыздағы Cobalt деректері</translation>
<translation id="3387107508582892610">{THRESHOLD,plural, =1{Бұл жағдай Cobalt браузері {THRESHOLD} минут қолданылмаған кезде орын алады. Оған тарих пен автотолтыру кіруі мүмкін.}other{Бұл жағдай Cobalt браузері {THRESHOLD} минут қолданылмаған кезде орын алады. Оған тарих пен автотолтыру кіруі мүмкін.}}</translation>
<translation id="3472200483164753384">Cobalt Canary-де қолдау көрсетілмейді.</translation>
<translation id="347967311580159871">Cobalt тәжірибесін жақсарту үшін деректерді қолданатын басқа параметрлерді <ph name="BEGIN_LINK" />Google қызметтерінен<ph name="END_LINK" /> қараңыз.</translation>
<translation id="3512168799938877162">Құпия сөзіңіз жіберілмеді. Интернет байланысын тексеріп, Cobalt-ға кіріңіз. Одан кейін әрекетті қайталап көріңіз.</translation>
<translation id="3554027294407525061">Cobalt-дегі браузерді пайдалану деректерін тазалау.</translation>
<translation id="3567399274263440288">Cobalt-ді барынша пайдалану үшін оған Google аккаунтыңызбен кіріңіз.</translation>
<translation id="3634039384458740619">Cobalt параметрлерін ашыңыз.</translation>
<translation id="3639997914391704523">Google аккаунтыңызбен кіргенде, Cobalt сіздің құпия сөздеріңізді тексере алады.</translation>
<translation id="3650632991272923014"><ph name="USER_EMAIL1" /> Cobalt браузерін қолданған еді, сондықтан осы құрылғыда оның бетбелгілері, құпия сөздері және басқа да параметрлері қалып қойды.</translation>
<translation id="3688710892786762883">Cobalt сіз кіретін сайттардағы пакетті бақылау нөмірлерін анықтап, сізге пакет жаңартуларын "Жаңа қойынды" бетінен көрсетеді. Бұл функцияны ұсыну және сатып алу қызметін әркім үшін жақсарту мақсатында деректеріңіз Google-ға жіберіледі.</translation>
<translation id="372658070733623520">Google аккаунтыңызда Cobalt деректерін пайдалану және сақтау үшін жеке басыңызды растаңыз.</translation>
<translation id="3780779443901618967">Стандартты қорғанысқа қарағанда сайттардағы көбірек деректерді талдау арқылы қауіпті сайттар, тіпті Google-ға бұрын белгісіз болған сайттар туралы ескертеді. Cobalt ескертулерін өткізіп жіберуді таңдауға болады.</translation>
<translation id="3784369638459513223">Cobalt-нің жаңа инкогнито қойындысын ашады.</translation>
<translation id="3805899903892079518">Cobalt сурет пен бейнелерге кіре алмайды. "iOS параметрлері &gt; Құпиялық &gt; Фотосуреттер" арқылы рұқсат беру қажет.</translation>
<translation id="3827545470516145620">Бұл құрылғыда стандартты қауіпсіздік жүйесі қолданылады</translation>
<translation id="3833326979834193417">Cobalt деректерге рұқсатсыз қол сұғудан, қауіпті веб-сайттар мен басқа да зиян әрекеттерден қорғау үшін қауіпсіздік тексерісін күнде автоматты түрде жүргізеді. Қауіпсіздік тексерісі туралы толық ақпаратты параметрлерден қарасаңыз болады.</translation>
<translation id="3855938650519180865">Cobalt-дегі жаңалықтар</translation>
<translation id="3886689467633467988">Барлық құрылғыда бетбелгілер мен т.б. алу үшін осы сайт пен Cobalt-ге кіріңіз.</translation>
<translation id="3904484643286601695">Таңдауларды кез келген уақытта Cobalt параметрлерінде жаңарта аласыз.</translation>
<translation id="394413318816989199">Құпия фразаны шифрлауға төлеу әдістері мен мекенжайлар кірмейді.

Бұл параметрді өзгерту үшін <ph name="BEGIN_LINK" />аккаунтыңыздағы Cobalt деректерін өшіріңіз<ph name="END_LINK" />.</translation>
<translation id="3955621079070267756">Cobalt браузерін кез келген қолданбадан ашу</translation>
<translation id="4005283307739974863">Cobalt-дегі қауіпсіздік тексерісін ашады және жүргізеді.</translation>
<translation id="4043291146360695975">Құпия сөздер осы құрылғыда ғана Құпия сөздер реттегішіне сақталады.</translation>
<translation id="4076589763479456892">Құпия фразаны ұмытып қалған болсаңыз немесе осы параметрді өзгерту керек болса, <ph name="BEGIN_LINK" />аккаунтыңыздағы Cobalt деректерін өшіріңіз<ph name="END_LINK" />.</translation>
<translation id="4099085513035183040">Cobalt (бета нұсқасы) браузерінде қолдау көрсетілмейді.</translation>
<translation id="4106512142782407609"><ph name="EMAIL" /> аккаунтына кірдіңіз.

Деректер құпия фразаңызбен шифрланды. Google аккаунтыңызда Cobalt деректерін пайдалану және сақтау үшін оны енгізіңіз.</translation>
<translation id="4118287192800900567">Cobalt кеңесі: Cobalt аккаунтына кіріңіз</translation>
<translation id="4195557071150719219">Cobalt-дегі соңғы қойындыларды көру</translation>
<translation id="4200712796753248893">Cobalt-дегі әрекеттерді iOS-те пайдалану</translation>
<translation id="420541179527342563">Cobalt браузерінде құлыптау режимін өшіру үшін оны iPad құрылғыңызда өшіріңіз.</translation>
<translation id="4408912345039114853">Cobalt-нің қауіпсіздік тексерісін жүргізу</translation>
<translation id="4432744876818348753">Cobalt-ді толық қолдану үшін аккаунтқа кіріңіз.</translation>
<translation id="4445228361214254027">Ұйымыңыз Google аккаунтыңыздағы Cobalt деректерін пайдалану және сақтау қабілетін өшірді. Жаңа бетбелгілер, құпия сөздер және т.б. тек осы құрылғыға сақталады.</translation>
<translation id="4498832288620833153">Енгізілген URL мекенжайларын Cobalt-дегі оқу тізіміне қосады.</translation>
<translation id="452436063477828504">Google аккаунтыңызда Cobalt деректерін үнемі пайдалана алатыныңызға көз жеткізу</translation>
<translation id="4555020257205549924">Бұл функция қосылған кезде, Cobalt басқа тілдерде жазылған беттерді Google Translate арқылы аударуды ұсынады. <ph name="BEGIN_LINK" />Толығырақ<ph name="END_LINK" /></translation>
<translation id="4576283463017113841">Cobalt-дегі "Төлеу әдістерін орнату" бетін ашады.</translation>
<translation id="4585809515399340748">Енді кез келген уақытта хабарлардағы, құжаттардағы және басқа қолданбалардағы сілтемелерді түртіп, Cobalt браузерін пайдалана аласыз.</translation>
<translation id="459080529287102949">Cobalt-нен визуалдық графиканы іздеу</translation>
<translation id="4633738821577273991">Cobalt профилі үшін де Күшейтілген Safe Browsing қолжетімді.</translation>
<translation id="4638625642619341392">Cobalt-ді осы жерде жүктеп алыңыз.</translation>
<translation id="4654936625574199632">Қолданба жұмысын жақсарту үшін Cobalt пайдалану және бұзылу туралы деректерді Google-ға жібереді. <ph name="BEGIN_LINK" />Басқару<ph name="END_LINK" /></translation>
<translation id="4681781466797808448">Cobalt сканерін іске қосу</translation>
<translation id="4736424910885271643">Аккаунтыңызды <ph name="HOSTED_DOMAIN" /> басқарады, сондықтан Cobalt деректеріңіз бұл құрылғыдан өшіріледі</translation>
<translation id="4773487571745795781">Cobalt-мен кіру мүмкіндігін өшірдіңіз.</translation>
<translation id="4790638144988730920">Google аккаунтыңызда Cobalt деректерін пайдалануды жалғастырыңыз.</translation>
<translation id="4828317641996116749">Cobalt барлық құпия сөзді тексере алмады. Кейінірек қайталап көріңіз.</translation>
<translation id="4962295957157529683">Басқа ашық Cobalt терезесінде жасап жатқан нәрсеңізді аяқтаңыз.</translation>
<translation id="4985291216379576555">Офлайн, Cobalt жаңа нұсқалардың бар-жоғын тексере алмайды.</translation>
<translation id="4996471330284142407">Қарапайым, қауіпсіз әрі ең жылдам Cobalt-мен жұмыс өнімділігін арттырыңыз.</translation>
<translation id="4999538639245140991"><ph name="SIGNOUT_MANAGED_DOMAIN" /> басқаратын аккаунттан шықсаңыз, Cobalt деректеріңіз құрылғыдан жойылады. Деректеріңіз Google аккаунтында қалады.</translation>
