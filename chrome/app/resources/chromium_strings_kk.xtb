<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="kk">
<translation id="1001716830750249114">Cobalt нұсқасының параметрлеріне өту</translation>
<translation id="1026101648481255140">Орнатуды жалғастыру</translation>
<translation id="1029669172902658969">&amp;ChromiumOS жүйесін жаңарту үшін қайта іске қосу</translation>
<translation id="1040916596585577953">Cobalt осы кеңейтімді қарап шығуды ұсынады</translation>
<translation id="1042552502243217427">Сайт беттегі сілтемелерді құпия түрде алдын ала жүктеуді сұрағанда, Cobalt браузері Google серверлерін пайдаланады. Осылайша жеке деректеріңіз алдын ала жүктелетін сайттан жасырылады, бірақ Google алдын ала жүктелетін сайттарды біледі.</translation>
<translation id="1065672644894730302">Реттеулерді оқу мүмкін емес.

Кейбір мүмкіндіктер қолжетімсіз болуы мүмкін және параметрлерге жасалған өзгертулер сақталмайды.</translation>
<translation id="1083934481477628225">Ата-анаңыз Cobalt браузері үшін "Сайттарға, қолданбаларға және кеңейтімдерге арналған рұқсаттар" параметрін өшірді</translation>
<translation id="1098170124587656448">Cobalt деректердің қолды болуынан, сәйкес келмейтін кеңейтімдерден және тағы басқа мәселелерден қорғайды.</translation>
<translation id="1104942323762546749">Cobalt құпия сөздерді экспорттағысы келеді. Бұған рұқсат беру үшін Windows құпия сөзіңізді теріңіз.</translation>
<translation id="113122355610423240">Cobalt әдепкі браузеріңіз болып табылады</translation>
<translation id="1131805035311359397">Құпия сөздеріңіздің ұрланудан және басқа да қауіпсіздік мәселелерінен қаншалықты қорғалғанын тексеру үшін <ph name="BEGIN_LINK" />Cobalt браузеріне кіріңіз<ph name="END_LINK" />.</translation>
<translation id="1153368717515616349">Cobalt мәзірін басыңыз.</translation>
<translation id="1185134272377778587">Cobalt туралы ақпарат</translation>
<translation id="1203500561924088507">Орнатқаныңыз үшін рақмет. <ph name="BUNDLE_NAME" /> пайдаланбас бұрын браузерді жауып, қайта ашуыңыз керек.</translation>
<translation id="1262876892872089030">Бұл қойынды әрекетсіз тұрған кезде, Cobalt жылдам жұмыс істеуі үшін, жад босатылды. Сіз бұл сайтты әрекетсіз тұру тізімінен әрдайым шығарып отыру опциясын таңдай аласыз.</translation>
<translation id="1265577313130862557">Cobalt жүктеп алуды блоктады, себебі бұл файл қауіпті.</translation>
<translation id="1315551408014407711">Жаңа Cobalt профилінің параметрлерін реттеу</translation>
<translation id="1342274909142618978">Деректерді Cobalt-нен (<ph name="URL" />) де жою</translation>
<translation id="1414495520565016063">Cobalt жүйесіне кірдіңіз!</translation>
<translation id="1478370723027452770">Chrome for Testing бойынша анықтама алу</translation>
<translation id="1497802159252041924">Орнату қатесі: <ph name="INSTALL_ERROR" /></translation>
<translation id="1524282610922162960">Cobalt қойындысын бөлісу</translation>
<translation id="1553461853655228091">Cobalt браузеріне айналаңыздың 3D картасын жасау үшін камераны пайдалану рұқсаты керек.</translation>
<translation id="1574377791422810894">Cobalt-нің қауіпсіздік құралдары</translation>
<translation id="1607715478322902680">{COUNT,plural, =0{Жаңартылған нұсқаны қолдану үшін әкімшіңіз Cobalt браузерін қайта іске қосуыңызды талап етеді.}=1{Жаңартылған нұсқаны қолдану үшін әкімшіңіз Cobalt браузерін қайта іске қосуыңызды талап етеді. Инкогнито терезесі қайта ашылмайды.}other{Жаңартылған нұсқаны қолдану үшін әкімшіңіз Cobalt браузерін қайта іске қосуыңызды талап етеді. # инкогнито терезесі қайта ашылмайды.}}</translation>
<translation id="1625909126243026060">Cobalt-дегі құпиялық пен қауіпсіздікті басқарудың маңызды құралдарын қарап шығыңыз.</translation>
<translation id="1632539827495546968">Егер осы аккаунтты бір рет қана пайдаланғыңыз келсе, Cobalt браузерінде <ph name="GUEST_LINK_BEGIN" />Қонақ режимін<ph name="GUEST_LINK_END" /> қоса аласыз. Аккаунтты әлдекімге қосқыңыз келсе, <ph name="DEVICE_TYPE" /> құрылғысына <ph name="LINK_BEGIN" />жаңа адам қосыңыз<ph name="LINK_END" />.

Веб-сайттар мен қолданбаларға берілген рұқсаттар осы аккаунтқа пайдаланылуы мүмкін. Google аккаунттарын <ph name="SETTINGS_LINK_BEGIN" />Параметрлер<ph name="SETTINGS_LINK_END" /> бөлімінен басқаруға болады.</translation>
<translation id="1640672724030957280">Жүктеп алынып жатыр…</translation>
<translation id="1708666629004767631">Cobalt жүйесінің жаңа, қауіпсіз нұсқасы қолжетімді.</translation>
<translation id="1715127912119967311">Бұл функцияларды жақсарту үшін Cobalt оларды қолдануыңыз туралы ақпаратты Google-ға жібереді. Бұл деректерді тексерушілер оқуы, өңдеуі және aннотация қосуы мүмкін.</translation>
<translation id="17264556997921157">Сайттардың жарнама көрсетуге пайдаланған қызық тақырыптарын көре және өшіре аласыз. Cobalt браузерді қолданудың соңғы тарихына сүйене отырып, сізге қызық болар деген тақырыптарды болжайды.</translation>
<translation id="1733725117201708356">Cobalt жақын арада браузерді пайдалану деректерін жояды</translation>
<translation id="1736443181683099871">Cobalt браузері навигацияларды HTTPS кеңейтіміне жаңартып көреді.</translation>
<translation id="1745121272106313518">Cobalt <ph name="REMAINING_TIME" /> кейін қайта қосылады</translation>
<translation id="1749104137266986751">HTTPS қолжетімді болмаған кезде, Cobalt сізге ескертпестен, қауіпті байланысты пайдаланады.</translation>
<translation id="1774152462503052664">Cobalt жүйесін фонда іске қосуға рұқсат беру</translation>
<translation id="1779356040007214683">Cobalt қауіпсіз ету үшін <ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> ішінде көрсетілмеген және сізге білдірмей қосылған болуы мүмкін кейбір кеңейтімдерді өшірдік.</translation>
<translation id="1808667845054772817">Cobalt қайта орнату</translation>
<translation id="1820835682567584003">Cobalt <ph name="AUTHENTICATION_PURPOSE" /> қолданып көрейін деп жатыр</translation>
<translation id="185970820835152459">Кірген Google аккаунттарыңызды басқара аласыз. Google аккаунттарыңыз Cobalt браузері, Play Store, Gmail және тағы басқа қызметтерде пайдаланылады. Егер отбасы мүшесі сияқты әлдебіреудің аккаунтын қосқыңыз келсе, жаңа пайдаланушыны <ph name="DEVICE_TYPE" /> құрылғыңызға қосыңыз. <ph name="LINK_BEGIN" />Толығырақ<ph name="LINK_END" /></translation>
<translation id="1863308913976887472">Сайттар Cobalt браузерінде қызығушылықтарыңыз туралы ақпаратты сақтай алады. Мысалы, марафонға аяқ киім сатып алу үшін сайтқа кірсеңіз, сайт қызығушылығыңызды марафон жүгіру деп анықтауы мүмкін. Кейін жүгіру жарысына тіркелу үшін басқа сайтқа кірсеңіз, сол сайт қызығушылықтарыңыз негізінде кроссовка жарнамасын көрсетуі мүмкін.</translation>
<translation id="1881322772814446296">Бақыланатын аккаунт арқылы кіріп, оның әкімшісіне Cobalt профиліңізді басқару мүмкіндігін бердіңіз. Қолданбалар, бетбелгілер, журнал, құпия сөздер сияқты Cobalt деректеріңіз және басқа параметрлер біржола <ph name="USER_NAME" /> пайдаланушысына байланыстырылады. Бұл деректерді Google аккаунт бақылау тақтасы арқылы жоя аласыз, бірақ бұл деректерді басқа аккаунтмен байланыстыра алмайсыз. Бар Cobalt деректерін бөлек ұстау үшін қосымша жаңа профиль жасай аласыз. <ph name="LEARN_MORE" /></translation>
<translation id="1906696617298807388">Мекенжай жолағында немесе іздеу өрісінде терген кезде, Cobalt браузері элемент ұсыныстарын алу үшін тергеніңізді Google Drive қызметіне жібереді. Бұл Инкогнито режимінде өшірілген.</translation>
<translation id="1911763535808217981">Бұл функцияны өшіріп, Cobalt браузеріне кірместен Gmail сияқты Google сайттарын пайдалана беруіңізге болады</translation>
<translation id="1929939181775079593">Cobalt жауап бермейді. Қазір қайта іске қосасыз ба?</translation>
<translation id="193439633299369377">Жаңарту күшіне енуі үшін ChromiumOS жүйесін өшіріп қосу керек.</translation>
<translation id="1951406923938785464">Cobalt жүктеп алуды блоктады, себебі бұл файл түрі әдетте жүктеп алынбайды және ол қауіпті болуы мүмкін.</translation>
<translation id="1953553007165777902">Жүктеп алынып жатыр… <ph name="MINUTE" /> минут қалды.</translation>
<translation id="1966382378801805537">Cobalt әдепкі браузерді анықтай не орната алмайды</translation>
<translation id="2008474315282236005">Құрылғыдан 1 элемент жойылады. Деректерді кейінірек алу үшін Cobalt браузеріне <ph name="USER_EMAIL" /> болып кіріңіз.</translation>
<translation id="2018879682492276940">Орнатылмады. Қайталап көріңіз.</translation>
<translation id="2020032459870799438">Басқа құпия сөздеріңіздің ұрланудан және басқа да қауіпсіздік мәселелерінен қаншалықты қорғалғанын тексеру үшін <ph name="BEGIN_LINK" />Cobalt браузеріне кіріңіз<ph name="END_LINK" />.</translation>
<translation id="2049376729098081731">Google қызметтерінде жекелендірілген мүмкіндіктерді пайдалану үшін Cobalt тарихын қосу-қоспау нұсқасын таңдаңыз.</translation>
<translation id="2086476982681781442">Cobalt жүктеп алуды блоктады, себебі бұл – алдамшы файл және ол құрылғыңызға күтпеген өзгерістер енгізуі мүмкін.</translation>
<translation id="2088953378266246249">Cobalt-нің түбірлік сертификаттарды қалай басқаратыны туралы ақпарат</translation>
<translation id="2120965832000301375">{COUNT,plural, =1{Cobalt 1 минут бойы пайдаланылмаса, ұйымыңыз браузерді пайдалану деректерін автоматты түрде жояды. Оларға тарих, автотолтыру және жүктеп алынғандар кіруі мүмкін. Қойындыларыңыз ашық болады.}other{Cobalt # минут бойы пайдаланылмаса, ұйымыңыз браузерді пайдалану деректерін автоматты түрде жояды. Оларға тарих, автотолтыру және жүктеп алынғандар кіруі мүмкін. Қойындыларыңыз ашық болады.}}</translation>
<translation id="2126108037660393668">Жүктеп алынған файл растаудан өтпеді.</translation>
<translation id="2130870084309816036">Интернетке қосылу мүмкін емес. Егер брандмауэр пайдалансаңыз, <ph name="PRODUCT_EXE_NAME" /> кеңейтімін рұқсат тізіміне қосыңыз.</translation>
<translation id="215352261310130060">Cobalt жүктеп алуды блоктады, себебі сайтта қауіпсіз байланыс пайдаланылып жатқан жоқ және файл өзгертілген болуы мүмкін.</translation>
<translation id="2174178932569897599">Cobalt-ді реттеу</translation>
<translation id="2174917724755363426">Орнату аяқталмады. Шынымен бас тартқыңыз келе ме?</translation>
<translation id="2185166961232948079">Cobalt – Желіге кіру - <ph name="PAGE_TITLE" /></translation>
<translation id="2190166659037789668">Жаңа нұсқаны тексеру қатесі: <ph name="UPDATE_CHECK_ERROR" />.</translation>
<translation id="2241627712206172106">Компьютерді бөлісетін болсаңыз, достарыңыз интернетке бөлек кіріп, Cobalt жүйесін қалауынша орната алады.</translation>
<translation id="2313870531055795960">URL мекенжайларын Cobalt браузерінде сақталған қауіпсіз емес сайттар тізімімен салыстырып тексереді. Егер сайт құпия сөзіңізді ұрлағысы келсе немесе зиянды файлды жүктеп алсаңыз, Cobalt браузері URL мекенжайларын, сондай-ақ бет контенті бөліктерін Safe Browsing қызметіне жіберуі мүмкін.</translation>
<translation id="2329088755516916767">Қосылса, Cobalt беттерді алдын ала жүктейді, осылайша браузерді пайдалану және іздеу әрекеті тез жүреді.</translation>
<translation id="2343156876103232566">Нөмірді осы жерден Android телефонына жіберу үшін екі құрылғыда да Cobalt браузеріне кіріңіз.</translation>
<translation id="2359808026110333948">Жалғастыру</translation>
<translation id="2359920621792549529">Браузерді пайдалану деректерін Google аккаунтында сақтай отырып, тек осы құрылғыдан өшіру үшін <ph name="BEGIN_LINK" />Cobalt-де аккаунттан шығыңыз<ph name="END_LINK" />.</translation>
<translation id="2384373936468275798">ChromiumOS деректеріңізді синхрондай алмады, себебі аккаунтыңызға кіру мәліметтері ескірген.</translation>
<translation id="2398377054246527950">{NUM_DEVICES,plural, =0{1 HID құрылғысын бір немесе бірнеше Cobalt кеңейтімі пайдаланды}=1{1 HID құрылғысын бір немесе бірнеше Cobalt кеңейтімі пайдаланып жатыр}other{# HID құрылғысын бір немесе бірнеше Cobalt кеңейтімі пайдаланып жатыр}}</translation>
<translation id="2401032172288869980">Cobalt бұл сайт үшін камера мен микрофонды пайдалануға рұқсат сұрайды.</translation>
<translation id="2440750600860946460"><ph name="BEGIN_LINK" />Cobalt-дегі құралдар<ph name="END_LINK" /> көмегімен браузерді қауіпсіз қолданып, барлығын басқаруға болады.</translation>
<translation id="2451727308784734061">Password Manager қызметіне жылдам өту үшін таңбашаны пайдаланыңыз. Таңбашаны компьютердің негізгі экранына немесе қолданбаларды іске қосу тақтасына жылжытуға болады.</translation>
<translation id="2478295928299953161">Cobalt жақын арада жабылады</translation>
<translation id="2483889755041906834">Cobalt аясында</translation>
<translation id="2485422356828889247">Жою</translation>
<translation id="2513154137948333830">Өшіріп қосу қажет: <ph name="INSTALL_SUCCESS" /></translation>
<translation id="2554739539410784893">Cobalt бұрыннан бар құпия сөздерді ауыстырғысы келеді. Бұған рұқсат беру үшін Windows құпия сөзін енгізіңіз.</translation>
<translation id="2560420686485554789">Файлдарды жүктеп алу үшін Cobalt браузеріне сақтау орнын пайдалану құқығы қажет</translation>
<translation id="2572494885440352020">Cobalt Helper</translation>
<translation id="2583187216237139145">Жұмыс профилінің әкімшісі осы профильді пайдалану кезінде құрылатын Cobalt браузерінің кез келген дерегін (бетбелгілер, тарих, құпия сөздер жасау және басқа параметрлер сияқты) жоя алады. <ph name="LEARN_MORE" /></translation>
<translation id="2592940277904433508">Cobalt-ді пайдалана беру</translation>
<translation id="259935314519650377">Жүктеп алынған орнату құралы кэштелмеді. Қате: <ph name="UNPACK_CACHING_ERROR_CODE" />.</translation>
<translation id="264613044588233783">Cobalt жылдам жұмыс істейді және JavaScript қолданатын функциялар тиісті түрде жұмыс істеуі керек (ұсынылады).</translation>
<translation id="2648074677641340862">Орнату барысында операциялық жүйе қатесі орын алды. Cobalt қайта жүктеңіз.</translation>
<translation id="2661879430930417727">Құрылғыңызды басқа адамдар да пайдаланатын болса, достарыңыз және отбасыңыздың мүшелері интернетке бөлек кіріп, Cobalt параметрлерін өздері қалағандай орната алады.</translation>
<translation id="268602741124540128"><ph name="ACCOUNT_FIRST_NAME" />, Cobalt браузеріне қош келдіңіз!</translation>
<translation id="2711502716910134313">Cobalt қойындысы</translation>
<translation id="2718390899429598676">Қосымша қауіпсіздік үшін Cobalt деректеріңізді шифрлайды.</translation>
<translation id="2738871930057338499">Интернетке қосылу мүмкін емес. HTTP 403 бойынша тыйым салынған. Прокси конфигурациясын тексеріңіз.</translation>
<translation id="2770231113462710648">Әдепкі браузерді келесіге өзгерту:</translation>
<translation id="2785438272836277133">Бұл кеңейтімде зиянды бағдарлама бар болғандықтан, ол қауіпті. Сіз кірген сайттардағы деректеріңізді, оның ішінде жеке ақпаратыңызды бұдан былай көрмеуі және өзгерте алмауы үшін, оны Cobalt-нан жойыңыз.</translation>
<translation id="2799223571221894425">Қайта іске қосу</translation>
<translation id="2837693172913560447"><ph name="USER_EMAIL_ADDRESS" /> үшін жаңа Cobalt профилі жасалады.</translation>
<translation id="2846251086934905009">Орнату қатесі: орнату аяқталмады, оның орнына доғарылды.</translation>
<translation id="2847479871509788944">Cobalt жүйесінен алып тастау…</translation>
<translation id="2850691299438350830">Аккаунтқа кірген кезде, Cobalt браузерінде қауіпсіздігіңізді қамтамасыз етеді және басқа Google қолданбаларында қауіпсіздік деңгейін арттыру үшін пайдаланылуы мүмкін.</translation>
<translation id="2885378588091291677">Тапсырмалар реттегіші</translation>
<translation id="2910007522516064972">&amp;Cobalt туралы</translation>
<translation id="2915996080311180594">Кейін қайта қосу</translation>
<translation id="2928420929544864228">Орнату аяқталды.</translation>
<translation id="2945997411976714835">Орнату қатесі: орнату процесі басталмады.</translation>
<translation id="2977470724722393594">Cobalt жаңартылған</translation>
<translation id="2977506796191543575">Егер сайт құпия сөзіңізді ұрлағысы келсе немесе зиянды файлды жүктеп алсаңыз, Cobalt браузері URL мекенжайларын, сондай-ақ бет контенті бөліктерін Safe Browsing қызметіне жіберуі мүмкін.</translation>
<translation id="3032706164202344641">Cobalt сіздің құпия сөздеріңізді тексере алмай жатыр. Кейінірек қайталап көріңіз.</translation>
<translation id="3032787606318309379">Cobalt жүйесіне қосылуда…</translation>
<translation id="3038232873781883849">Сәлден соң орнатыла бастайды…</translation>
<translation id="3068187312562070417">Басқа Cobalt профильдері</translation>
<translation id="3068515742935458733">Google компаниясына жаңылыс туралы есептер және <ph name="UMA_LINK" /> жіберу арқылы Cobalt жақсартуға көмектесіңіз</translation>
<translation id="3079753320517721795">{NUM_DEVICES,plural, =0{1 USB құрылғысын бір немесе бірнеше Cobalt кеңейтімі пайдаланды}=1{1 USB құрылғысын бір немесе бірнеше Cobalt кеңейтімі пайдаланып жатыр}other{# USB құрылғысын бір немесе бірнеше Cobalt кеңейтімі пайдаланып жатыр}}</translation>
<translation id="3101560983689755071">Браузерді қолдану тарихы төменде берілгендей сіз көретін жарнамаларға және қызығушылықтарға әсер етеді. Құпиялығыңызды сақтау үшін Cobalt қызығушылықтарды ай сайын автоматты түрде жойып отырады. Қызығушылықтарды өшірмесеңіз, олар жаңартыла беруі мүмкін.</translation>
<translation id="3103660991484857065">Орнату құралы мұрағаттан шығара алмады. Cobalt қолданбасын қайта жүктеңіз.</translation>
<translation id="3130323860337406239">Cobalt микрофоныңызды пайдалануда.</translation>
<translation id="3155163173539279776">Cobalt қолданбасын қайта іске қосу</translation>
<translation id="3179665906251668410">Сілтемені Cobalt инкогнито терезесінде ашу</translation>
<translation id="3185330573522821672">Жаңа Cobalt профилін реттеңіз.</translation>
<translation id="3190315855212034486">Cobalt жаңылысты. Қазір қайта іске қосу керек пе?</translation>
<translation id="3258596308407688501">Cobalt өзінің деректер каталогін оқи және оған жаза алмайды:

<ph name="USER_DATA_DIRECTORY" /></translation>
<translation id="3268051428841342958">V8 — сайт өнімділігін арттыру үшін қолданылатын Cobalt-нің JavaScript және WebAssembly жүйесі.</translation>
<translation id="3283186697780795848">Cobalt браузерінің <ph name="PRODUCT_VERSION" /> нұсқасы орнатылды.</translation>
<translation id="3286538390144397061">Қазір қайта іске қосу</translation>
<translation id="328888136576916638">Google API пернелері жоқ. Кейбір Cobalt функциялары өшіріледі.</translation>
<translation id="3296368748942286671">Cobalt жабылғанда, фондық қолданбаларды пайдалануды жалғастыру</translation>
<translation id="3313189106987092621">Cobalt кез келген сайтты қауіпті байланыс арқылы жүктеу алдында сізге ескертеді.</translation>
<translation id="3350761136195634146">Бұл аккаунтқа Cobalt профилі тіркеліп қойған.</translation>
<translation id="3387527074123400161">ChromiumOS</translation>
<translation id="3406848076815591792">Бұрыннан бар Cobalt профиліне ауыстырылсын ба?</translation>
<translation id="3412460710772753638">Осы құрылғыдағы Құпия сөз менеджерінде</translation>
<translation id="3430503420100763906">Cobalt профильдері арқылы Cobalt-дегі материалдарыңызды бөліп қоя аласыз. Достарға және отбасыңызға арнап немесе жұмысқа не көңіл көтеруге бөлек профиль жасаңыз.</translation>
<translation id="347328004046849135">Ұрланған құпия сөзбен кірген кезде, Cobalt сізге хабарлайды.</translation>
<translation id="3474745554856756813">Құрылғыдан <ph name="ITEMS_COUNT" /> элемент жойылады. Деректерді кейінірек алу үшін Cobalt браузеріне <ph name="USER_EMAIL" /> болып кіріңіз.</translation>
<translation id="3497319089134299931"><ph name="SHORTCUT" /> арқылы Cobalt профильдерін ауыстыруға болады.</translation>
<translation id="3509308970982693815">Барлық Cobalt терезелерін жауып, әрекетті қайталап көріңіз.</translation>
<translation id="3533435340678213462">Құпиялығыңызды сақтау үшін 4 аптадан көп көрсетілген қызығушылықтарды автоматты түрде жойып отырамыз. Интернетті шолу кезінде белгілі бір қызығушылық тізімде қайтадан шығуы мүмкін. Бұл ретте Cobalt-ның ескергенін қаламаған қызығушылықтарды өшіруге болады.</translation>
<translation id="3567254597502212821">Браузерді қолдану тарихы, осы құрылғыда Cobalt көмегімен кірген сайттардың жазбасы.</translation>
<translation id="3593091352817399191">Басқа аккаунт кіріп қойған. Браузерді пайдалану тарихын бөлек сақтау үшін Cobalt сізге жеке профиль жасай алады.</translation>
<translation id="3639635944603682591">Бұл пайдаланушының браузерді пайдалану деректері құрылғыдан жойылады. Деректерді қалпына келтіру үшін Cobalt браузеріне <ph name="USER_EMAIL" /> болып кіріңіз.</translation>
<translation id="364817392622123556">{COUNT,plural, =0{Cobalt браузерінің жаңа нұсқасы шықты. Ол браузерді өшіріп, қайта іске қосқанда орнатылады.}=1{Cobalt браузерінің жаңа нұсқасы шықты. Ол браузерді өшіріп, қайта іске қосқанда орнатылады. Инкогнито терезесі қайта ашылмайды.}other{Cobalt браузерінің жаңа нұсқасы шықты. Ол браузерді өшіріп, қайта іске қосқанда орнатылады. # инкогнито терезесі қайта ашылмайды.}}</translation>
<translation id="3651803019964686660">Нөмірді <ph name="ORIGIN" /> құрылғысынан Android телефонына жіберу үшін екі құрылғыда да Cobalt браузеріне кіріңіз.</translation>
<translation id="3667616615096815454">Орнату мүмкін болмады, себебі сервер қолданбаны анықтай алмады.</translation>
<translation id="3685209450716071127">Cobalt сіздің құпия сөздеріңізді тексере алмай жатыр. Интернет байланысын тексеріп көріңіз.</translation>
<translation id="3702352323269013324">Cobalt браузерінде жарнаманы жекелендіру туралы толық ақпарат</translation>
<translation id="370962675267501463">{COUNT,plural, =0{Жаңартылған нұсқасын қолдану үшін әкімші Cobalt-ді қайта іске қосуыңызды сұрайды.}=1{Жаңартылған нұсқасын қолдану үшін әкімші Cobalt-ді қайта іске қосуыңызды сұрайды. Инкогнито терезесі қайта ашылмайды.}other{Жаңартылған нұсқасын қолдану үшін әкімші Cobalt-ді қайта іске қосуыңызды сұрайды. # инкогнито терезесі қайта ашылмайды.}}</translation>
<translation id="3713809861844741608">Сілтемені жаңа Cobalt қойындысында ашу</translation>
<translation id="3788675262216168505">Cobalt профильдерін басқару</translation>
<translation id="378917192836375108">Cobalt вебтегі телефон нөмірін басып, оған Skype арқылы қоңырау шалу мүмкіндігін береді!</translation>
<translation id="3790262771324122253">Неліктен Cobalt кейбір жүктеп алынғандарды блоктайтыны туралы ақпарат алыңыз</translation>
<translation id="379589255253486813">Тексеруге қажетті нәрсе болса, Cobalt сізге хабар береді</translation>
<translation id="3802055581630249637">Cobalt сіз кіруіңіз мүмкін беттерді алдын ала жүктейді, сонда оларға кірген кезіңізде, тезірек жүктеледі.</translation>
<translation id="3830894615770080216">ChromiumOS жүйесі</translation>
<translation id="3848258323044014972"><ph name="PAGE_TITLE" /> – Cobalt</translation>
<translation id="386822487697155367">ChromiumOS туралы анықтама алу</translation>
<translation id="3871664619793219264"><ph name="ACCOUNT_EMAIL" /> аккаунтынан Cobalt браузерінің мәліметтерін алыңыз.</translation>
<translation id="388648406173476553">Cobalt-ді реттеу және басқару. Назар аударуыңыз қажет. Толығырақ ақпарат алу үшін басыңыз.</translation>
<translation id="3889543394854987837">Cobalt ашу үшін атыңызды басып, шарлауды бастаңыз.</translation>
<translation id="390528597099634151"><ph name="EXISTING_USER" /> бұл Cobalt профиліне кіріп қойған. Браузерді пайдалану деректерін бөлек сақтау үшін Cobalt сізге жеке профиль жасай алады.</translation>
<translation id="3909353120217047026">Бұл кеңейтім Chrome Web Store саясатына қайшы, сондықтан қауіпті болуы мүмкін. Сіз кірген сайттардағы деректеріңізді, оның ішінде жеке ақпаратыңызды бұдан былай көрмеуі және өзгерте алмауы үшін, оны Cobalt-нан жойыңыз.</translation>
<translation id="391789666908693569">Аккаунтыңызды <ph name="MANAGER_NAME" /> басқарады. Әкімші осы Cobalt браузерінің профилі мен оның бетбелгілер, тарих және құпия сөздер сияқты деректерін көре және өзгерте алады.</translation>
<translation id="3941890832296813527">Орнату қатесі: орнату файлының атауы жарамсыз немесе оған қолдау көрсетілмейді.</translation>
<translation id="3945058413678539331">Cobalt құпия сөздерді көшіргісі келеді. Бұған рұқсат беру үшін Windows құпия сөзіңізді теріңіз.</translation>
<translation id="3962647064319009959">Cobalt сізді қалай қорғайтыны туралы ақпарат алыңыз</translation>
<translation id="3975724895399328945">&amp;Google Chrome for Testing туралы</translation>
<translation id="3997429360543082038">ChromiumOS туралы</translation>
<translation id="4019629340646866719">ChromiumOS жүйесі де <ph name="BEGIN_LINK_LINUX_OSS" />Linux әзірлеу ортасы<ph name="END_LINK_LINUX_OSS" /> сияқты <ph name="BEGIN_LINK_CROS_OSS" />ашық кодты бағдарламалық құрал<ph name="END_LINK_CROS_OSS" /> арқылы қолжетімді болады.</translation>
<translation id="4036079820698952681"><ph name="BEGIN_LINK" />Ағымдағы параметрлерді<ph name="END_LINK" /> хабарлау арқылы Cobalt браузерін жақсартуға көмектесіңіз</translation>
<translation id="4050175100176540509">Соңғы нұсқасында қауіпсіздік жақсартылып, жаңа мүмкіндіктер берілген.</translation>
<translation id="4055805654398742145">P&amp;assword Manager</translation>
<translation id="4095980151185649725">{COUNT,plural, =1{Cobalt 1 минут бойы пайдаланылмаса, ұйымыңыз оны автоматты түрде жабады. Браузерді пайдалану деректері жойылады. Оларға тарих, автотолтыру және жүктеп алынғандар кіруі мүмкін.}other{Cobalt # минут бойы пайдаланылмаса, ұйымыңыз оны автоматты түрде жабады. Браузерді пайдалану деректері жойылады. Оларға тарих, автотолтыру және жүктеп алынғандар кіруі мүмкін.}}</translation>
<translation id="4118474109249235144">Cobalt-нің инкогнито режимі</translation>
<translation id="4148957013307229264">Орнатылуда…</translation>
<translation id="419998258129752635"><ph name="PAGE_TITLE" /> –Желіге кіру – Cobalt</translation>
<translation id="421369550622382712">Cobalt үшін тамаша қолданбалар, ойындар мен тақырыптарды таба аласыз.</translation>
<translation id="4216212958613226427">Бұл тіл Cobalt интерфейсін көрсету үшін қолданылады.</translation>
<translation id="4222932583846282852">Бас тартылуда…</translation>
<translation id="4230135487732243613">Cobalt дерегіңізді осы аккаунтпен байланыстырасыз ба?</translation>
<translation id="4251772536351901305">Стандартты қорғанысқа қарағанда сайттардағы көбірек деректерді талдау арқылы қауіпті сайттар, тіпті Google-ға бұрын белгісіз болған сайттар туралы ескертеді. Cobalt ескертулерін өткізіп жіберуді таңдауға болады.</translation>
<translation id="4271805377592243930">Cobalt жөнінде анықтама алу</translation>
<translation id="4281844954008187215">Қызмет көрсету шарттары</translation>
<translation id="4285930937574705105">Орнату анықталмаған қате себебінен сәтсіз аяқталды. Ағымда Cobalt жұмыс істеп тұрса, оны жауып, әрекетті қайталаңыз.</translation>
<translation id="4304713468139749426">Құпия сөздер реттегіші</translation>
<translation id="4334294535648607276">Жүктеп алынды.</translation>
<translation id="439358628917130594">Бұл құрылғыны пайдаланбас бұрын, <ph name="MANAGER" /> домені келесі Қызмет көрсету шарттарын оқып, қабылдауыңызды талап етеді. Бұл шарттар ChromiumOS Шарттарын толықтырмайды, өзгертпейді және шектемейді.</translation>
<translation id="4407044323746248786">Cobalt браузерінен бәрібір шығасыз ба?</translation>
<translation id="4415566066719264597">Cobalt браузеріне фондық режимде жұмыс істеуге рұқсат беру</translation>
<translation id="4423735387467980091">Cobalt реттеу және басқару</translation>
<translation id="4427306783828095590">Жақсартылған қорғаныс фишинг пен зиянды бағдарламаларды бөгеуде көбірек істейді.</translation>
<translation id="4447409407328223819">Chrome for Testing туралы</translation>
<translation id="4501471624619070934">Орнату мүмкін болмады, себебі бұл елде кіруге шектеу қойылған.</translation>
<translation id="452711251841752011">Cobalt браузеріне қош келдіңіз! Жаңа браузер терезесі ашылды.</translation>
<translation id="4544142686420020088">Cobalt жаңартылған жоқ. Бірдеңе дұрыс болмады. <ph name="BEGIN_LINK" />Cobalt браузеріндегі жаңартуға қатысты мәселелерді түзетіңіз.<ph name="END_LINK" /></translation>
<translation id="454579500955453258">Жаңа Cobalt профилінде жалғастырылсын ба?</translation>
<translation id="4567424176335768812"><ph name="USER_EMAIL_ADDRESS" /> ретінде кіргенсіз. Енді барлық кірген құрылғыларда бетбелгілеріңізді, журналыңызды және басқа параметрлерді көре аласыз.</translation>
<translation id="4570813286784708942">Cobalt жүктеп алуды блоктады, себебі Safe Browsing функциясы өшірілді және файлды растау мүмкін емес.</translation>
<translation id="4594305310729380060">Осы құрылғыдағы Құпия сөз менеджеріне</translation>
<translation id="459535195905078186">Cobalt қолданбалары</translation>
<translation id="4613863813562375431">ChromiumOS нұсқасы</translation>
<translation id="4621240073146040695">Сәл қалды! Жаңартуды аяқтау үшін Cobalt жүйесін қайта іске қосыңыз.</translation>
<translation id="4665829708273112819">Ескерту: Cobalt кеңейтімдердің браузерді қолдану тарихын жазуына кедергі бола алмайды. Бұл кеңейтімді Инкогнито режимінде өшіру үшін бұл опцияның белгісін алып тастаңыз.</translation>
<translation id="4673151026126227699">Cobalt пайдалану есептерін де бөліссеңіз, бұл есептерде сіз кірген URL мекенжайлары қамтылады.</translation>
<translation id="4677944499843243528">Профиль басқа Cobalt процесімен (<ph name="PROCESS_ID" />) басқа компьютерде (<ph name="HOST_NAME" />) пайдаланылып жатыр. Бүлінбеуі үшін Cobalt профильді құлыптап қойды. Басқа процестер бұл профильді пайдаланып жатпаса, профильді құлыптан ашып, Cobalt қайта іске қосуыңызға болады.</translation>
<translation id="4680828127924988555">Орнатудан бас тарту</translation>
<translation id="4708774505295300557">Бұрын әлдекім осы компьютерден Cobalt браузеріне <ph name="ACCOUNT_EMAIL_LAST" /> болып кірген. Ақпаратты бөлек ұстау үшін жаңа Cobalt пайдаланушысын жасаңыз.</translation>
<translation id="4724676981607797757">Орнатылмады, себебі қолдау көрсетілмейтін протокол қатесі пайда болды.</translation>
<translation id="4746050847053251315">Cobalt браузерінен бәрібір шығасыз ба?</translation>
<translation id="4748217263233248895">Cobalt браузеріне қазір ғана қауіпсіздік бойынша арнайы жаңартылған нұсқа қолданылды. Оны қазір қайта ашсаңыз, қойындылар қалпына келтіріледі.</translation>
<translation id="4765210420921718862">Таңдауыңызды кез келген уақытта Cobalt параметрлерінде өзгертуге болады. Сынақ нұсқалары жарнама көрсетудің ағымдағы әдісімен жұмыс істейді. Сондықтан өзгерістер бірден көрінбейді.</translation>
<translation id="4788777615168560705">Cobalt сіздің құпия сөздеріңізді тексере алмай жатыр. 24 сағаттан кейін қайталап көріңіз немесе <ph name="BEGIN_LINK" />құпия сөздерді Google аккаунтынан тексеріңіз<ph name="END_LINK" />.</translation>
<translation id="479167709087336770">Google Search қызметіндегі емле тексеру құралы пайдаланылады. Браузерде терілген мәтін Google-ға жіберіледі. Мұны параметрлерде өзгертуіңізге болады.</translation>
<translation id="4814736265800133385">Cobalt-ді аккаунтсыз қолдану</translation>
<translation id="4888717733111232871">mDNS трафигіне рұқсат беретін Cobalt кіріс ережесі.</translation>
<translation id="4893347770495441059">&amp;Cobalt-ді жаңарту үшін қайта іске қосу</translation>
<translation id="4942295735032723435">Cobalt-нің жаңа нұсқаларын алып тұру үшін macOS 11 не одан кейінгі операциялық жүйе керек болады. Бұл компьютерде macOS 10.15 нұсқасы орнатылған.</translation>
<translation id="4943838377383847465">Cobalt фондық режимде.</translation>
<translation id="4987820182225656817">Қонақтар Cobalt қолданбасын ешқандай дерек қалдырмай пайдалана алады.</translation>
<translation id="4994636714258228724">Cobalt жүйесіне өзіңізді қосу</translation>
<translation id="5114678101347489141">Cobalt жаңа функцияларды зерттеп жатыр. Олардың көмегімен сайттарды аз ақпаратпен де бұрынғыдай пайдалана беруге болады.</translation>
<translation id="5224391634244552924">Ешқандай құпия сөз сақталмаған. Құпия сөздер сақталған кезде, Cobalt оларды тексере алады.</translation>
<translation id="5252179775517634216"><ph name="EXISTING_USER" /> бұл Cobalt профиліне кіріп қойған. <ph name="USER_EMAIL_ADDRESS" /> үшін жаңа Cobalt профилі жасалады.</translation>
<translation id="5277894862589591112">Өзгерістер енуі үшін, Cobalt браузерін қайта қосыңыз</translation>
<translation id="5294316920224716406">Инкогнито режимін пайдаланған кезде, Cobalt сайтты қауіпті байланыс арқылы жүктеу алдында сізге ескертеді.</translation>
<translation id="5296845517486664001">Сынақ нұсқалары қосылғанда, Cobalt сізді белсенді сынақ нұсқасына кездейсоқ орналастырса, браузерді қолдану тарихы төменде берілгендей сіз көретін жарнамалар мен қызығушылықтарға әсер етеді. Құпиялығыңызды сақтау үшін Cobalt қызығушылықтарды ай сайын жойып отырады.</translation>
<translation id="5352264705793813212">Cobalt тексеруге қажетті қауіпсіздікке қатысты кейбір ұсыныстарды тапты</translation>
<translation id="5352361688875342522">Басқа Cobalt профильдері</translation>
<translation id="5358375970380395591">Бақыланатын аккаунт арқылы кірдіңіз және оның әкімшілік бөлігін Cobalt профилі арқылы басқару мүмкіндігін бердіңіз. Қолданбалар, бетбелгілер, журнал, құпия сөздер сияқты Cobalt деректеріңіз және басқа параметрлер біржола <ph name="USER_NAME" /> пайдаланушысына байланыстырылады. Бұл деректерді Google аккаунт бақылау тақтасы арқылы жоя аласыз, бірақ бұл деректерді басқа аккаунтмен байланыстыра алмайсыз. <ph name="LEARN_MORE" /></translation>
<translation id="5368118228313795342">Қосымша код: <ph name="EXTRA_CODE" />.</translation>
<translation id="5383439451358640070">Неліктен Cobalt кейбір файлдарды блоктайтыны туралы ақпарат алыңыз</translation>
<translation id="5386450000063123300">Cobalt жаңартылуда (<ph name="PROGRESS_PERCENT" />)</translation>
<translation id="538767207339317086">Cobalt браузеріне кіруге рұқсат ету</translation>
<translation id="5398878173008909840">Жаңа Cobalt нұсқасы қолжетімді.</translation>
<translation id="5405650547142096840">Cobalt-нен жою</translation>
<translation id="5427571867875391349">Әдепкі браузер ретінде Cobalt қолданбасын орнату</translation>
<translation id="5438241569118040789"><ph name="PAGE_TITLE" /> - Cobalt бета нұсқасы</translation>
<translation id="5473971139929175403">Cobalt дұрыс жұмыс істемеуі мүмкін, себебі оған Linux жүйесінде қолдау көрсетілмейді.</translation>
<translation id="5480860683791598150">Бұл сайтқа көрсету үшін Cobalt браузері орналасқан жеріңізді білуі керек</translation>
<translation id="5487574057737591516">Құпиялығыңызды сақтау үшін 4 аптадан көп көрсетілген қызығушылықтарды автоматты түрде жойып отырамыз. Интернетті шолу кезінде белгілі бір қызығушылық тізімде қайтадан шығуы мүмкін. Егер Cobalt браузері қателессе немесе белгілі бір жарнамаларды көргіңіз келмесе, қызығушылықты өшіре аласыз.</translation>
<translation id="549669000822060376">Cobalt ең соңғы жүйе жаңартуларын орнатуда, күте тұрыңыз.</translation>
<translation id="5496810170689441661">Cobalt құпия сөздерді өзгерткісі келеді. Бұған рұқсат беру үшін Windows құпия сөзіңізді теріңіз.</translation>
<translation id="5527463683072221100">PDF-терді Cobalt-де ашу</translation>
<translation id="5623402015214259806">{0,plural, =0{Cobalt браузерінің жаңартылған нұсқасы қолжетімді}=1{Cobalt браузерінің жаңартылған нұсқасы қолжетімді}other{Cobalt браузерінің жаңартылған нұсқасы # күннен бері қолжетімді}}</translation>
<translation id="5643865575100044307">Cobalt браузерін жапқан кезде құрылғыңыздан сайт деректерін үнемі жою</translation>
<translation id="5653831366781983928">Cobalt браузерін қайта іске қосыңыз</translation>
<translation id="5690427481109656848">Google LLC</translation>
<translation id="5698481217667032250">Cobalt жүйесін осы тілде көрсету</translation>
<translation id="569897634095159764">Интернетке қосылу мүмкін емес. Прокси-сервер үшін аутентификация қажет.</translation>
<translation id="5809516625706423866">Интернетке қосылу мүмкін емес. HTTP 401 бойынша рұқсат берілмейді. Прокси конфигурациясын тексеріңіз.</translation>
<translation id="5862307444128926510">Cobalt жүйесіне қош келдіңіз</translation>
<translation id="5883558403894052917">Cobalt бұл элементтерде зиянды бағдарлама бар екенін анықтады:</translation>
<translation id="5889361821821684993">Браузеріңізде ең қауіпсіз параметрлер бар екеніне көз жеткізу үшін Cobalt жүйелі түрде тексереді. Пікіріңіз керек болса, сізге хабар жібереміз.</translation>
<translation id="5895138241574237353">Қайта іске қосу</translation>
<translation id="5903106910045431592"><ph name="PAGE_TITLE" /> – Желіге кіру</translation>
<translation id="5924017743176219022">Интернетке қосылып жатыр…</translation>
<translation id="5941711191222866238">Жию</translation>
<translation id="5972142260211327093">Cobalt сізді белсенді сынақ нұсқасына кездейсоқ орналастырса, браузерді қолдану тарихы төменде берілгендей көретін жарнамалар мен қызығушылықтарға әсер етеді. Құпиялығыңызды сақтау үшін Cobalt қызығушылықтарды ай сайын жойып отырады. Қызығушылықтарды өшірмесеңіз, олар жаңартыла береді.</translation>
<translation id="5986585015444752010">{COUNT,plural, =1{Cobalt 1 минут бойы пайдаланылмаса, ұйымыңыз оны автоматты түрде жабады.}other{Cobalt # минут бойы пайдаланылмаса, ұйымыңыз оны автоматты түрде жабады.}}</translation>
<translation id="5987687638152509985">Cobalt браузерін жаңартып, синхрондауды бастаңыз</translation>
<translation id="5988505247484123880">Әдетте кіретін сайттарыңыз тәжірибені жекелендіру үшін сізді қызықтыратын нәрселерді есте сақтайды. Сондай-ақ сайттар Cobalt браузерінде қызығушылықтарыңыз туралы ақпаратты сақтай алады.</translation>
<translation id="6003112304606738118">Жүктеп алынып жатыр… <ph name="HOURS" /> сағат қалды.</translation>
<translation id="6040143037577758943">Жабу</translation>
<translation id="6055895534982063517">Жаңа жылдамырақ Cobalt нұсқасы қолжетімді.</translation>
<translation id="6058380562449900225">Деректеріңізді қорғау үшін Cobalt-ге сіз соңғы уақытта кірмеген сайттар рұқсаттарын өшіруге рұқсат беріңіз. Хабарландырулар көрсетіле береді.</translation>
<translation id="6063093106622310249">&amp;Cobalt жүйесінде ашу</translation>
<translation id="6072279588547424923"><ph name="EXTENSION_NAME" /> кеңейтімі Cobalt браузеріне енгізілді</translation>
<translation id="6072463441809498330">Cobalt жылдамдығын арттырыңыз</translation>
<translation id="608006075545470555">Осы браузерге жұмыс профилін қосу</translation>
<translation id="6096348254544841612">Cobalt браузерін реттеңіз және басқарыңыз. Жаңартылған нұсқа қолжетімді.</translation>
<translation id="6102072151902574948">Қосулы болғанда, Cobalt браузері бірқалыпты айналдыру және бейненің кадр жиілігі сияқты фондық әрекеттерді және визуалдық әсерлерді шектеу арқылы батарея қуатын сақтайды.</translation>
<translation id="6119438414301547735">Кеңейтімге Cobalt құралдар тақтасында сайтқа кіру сұрауларын көрсетуге рұқсат беру</translation>
<translation id="6120345080069858279">Cobalt бұл құпия сөзді Google аккаунтыңызда сақтайды. Оны есте сақтаудың қажеті жоқ.</translation>
<translation id="6129621093834146363"><ph name="FILE_NAME" /> қауіпті болғандықтан, Cobalt оны бөгеді.</translation>
<translation id="6132897690380286411">Cobalt жақын арада жабылып, деректерді жояды</translation>
<translation id="6134968993075716475">"Қауіпсіз шолу" функциясы өшірулі. Cobalt браузері оны қосуды ұсынады.</translation>
<translation id="6144416395842701622">Cobalt-ді толық қолдану үшін аккаунтқа кіріңіз.</translation>
<translation id="6145820983052037069">Осы жерде Cobalt профильдерін ауыстыра аласыз.</translation>
<translation id="615103374448673771">Егер cookie файлдарына рұқсат берсеңіз, Cobalt оларды алдын ала жүктеу кезінде пайдалануы мүмкін.</translation>
<translation id="6174920971222007286">Бұл файл қауіпті болуы мүмкін.<ph name="LINE_BREAK" />Құпия сөзді көрсетсеңіз, Cobalt бұл жүктеп алу әрекетін тексере алады. Файл туралы ақпарат Google Safe Browsing қызметіне жіберіледі, бірақ файл контенті мен құпия сөз құрылғыңызда қалады.</translation>
<translation id="6182736845697986886">Орнатылмады, себебі жаңарту серверінде ішкі қате пайда болды.</translation>
<translation id="6183079672144801177"><ph name="TARGET_DEVICE_NAME" /> құрылғысындағы Cobalt браузеріне кіргеніңізді тексеріп, қайта жіберіп көріңіз.</translation>
<translation id="6212496753309875659">Бұл компьютерде жаңа Cobalt нұсқасы бұрыннан бар. Бағдарламалық жасақтама жұмыс істемесе, Cobalt жойып, әрекетті қайталап көріңіз.</translation>
<translation id="6219195342503754812">{0,plural, =0{Cobalt браузері қазір қайта іске қосылады}=1{Cobalt браузері 1 секундтан кейін қайта іске қосылады}other{Cobalt браузері # секундтан кейін қайта іске қосылады}}</translation>
<translation id="6241367896540709610">Cobalt файлдарды жүктеп алу үшін жадты пайдалануға рұқсат сұрайды.</translation>
<translation id="6245734527075554892">URL мекенжайларын Cobalt браузерінде сақталған қауіпсіз емес сайттар тізімімен салыстырып тексереді.</translation>
<translation id="6248213926982192922">Әдепкі браузер ретінде Cobalt орнату</translation>
<translation id="6266342355635466082">Cobalt жаңа нұсқалардың бар-жоғын тексере алмайды. Интернет байланысын тексеріп көріңіз.</translation>
<translation id="6268381023930128611">Cobalt жүйесінен шығасыз ба?</translation>
<translation id="6273793429163604305">Басталайын деп жатыр…</translation>
<translation id="6281746429495226318">Cobalt профилін реттеу</translation>
<translation id="6290827346642914212">Cobalt профиліне ат қойыңыз</translation>
<translation id="6295779123002464101"><ph name="FILE_NAME" /> қауіпті болуы мүмкін болғандықтан, Cobalt оны бөгеді.</translation>
<translation id="6309712487085796862">Cobalt камераңызды пайдалануда.</translation>
<translation id="632355235628111698">Бұл файл қауіпті болғандықтан, Cobalt оны бөгеді.</translation>
<translation id="6327105987658262776">Ешқандай жаңарту жоқ.</translation>
<translation id="6333502561965082103">Cobalt браузерінде басқа операция орындалуда. Әрекетті кейінірек қайталаңыз.</translation>
<translation id="6334986366598267305">Енді Cobalt қолданбасын Google аккаунтымен және ортақ компьютерлерде пайдалану жеңілірек.</translation>
<translation id="6366160072964553914">Cobalt жүктеп алуды блоктады, себебі бұл файл әдетте жүктеп алынбайды және ол қауіпті болуы мүмкін.</translation>
<translation id="6373523479360886564">Cobalt жою қажет пе?</translation>
<translation id="6375219077595103062">Password Manager таңбашасын қосу</translation>
<translation id="6384011394608460044"><ph name="BEGIN_BOLD" />Бұл дерек қалай пайдаланылады:<ph name="END_BOLD" /> Cobalt қызығушылықтарыңызды болжайды. Кейін сіз кірген сайт жарнамаларды жекелендіру үшін Cobalt браузерінен қызығушылықтарыңыз туралы ақпаратты сұрап алады.</translation>
<translation id="6400112897226594999">Компьютер экранындағы Cobalt логотипі.</translation>
<translation id="6403826409255603130">Cobalt — веб-беттер мен қолданбаларды өте жылдам ашатын веб-браузер. Ол жылдам, тұрақты және пайдалануға оңай. Cobalt жүйесіне ендірілген зиянды бағдарлама және фишинг қорғанысымен интернетті уайымсыз пайдалана беруіңізге болады.</translation>
<translation id="6442900851116057561">ChromiumOS жүйесін өшіріп қосу</translation>
<translation id="6443470774889161065">Cobalt сіз кіруіңіз мүмкін көбірек бетті алдын ала жүктейді, сонда оларға кірген кезіңізде, тезірек жүктеледі.</translation>
<translation id="6455857529632101747">Cobalt профильдеріне қош келдіңіз!</translation>
<translation id="6475912303565314141">Сонымен қатар Cobalt іске қосылғанда қайсы бет көрсетілуін бақылайды.</translation>
<translation id="648319183876919572">Күшейтілген Safe Browsing-нің қауіпті веб-сайттар мен файлдардан қорғау қабілеті жоғарырақ.</translation>
<translation id="6510925080656968729">Cobalt жою</translation>
<translation id="6539122709674868420">Ұйымыңыз Cobalt-ді <ph name="TIMEOUT_DURATION" /> бойы пайдаланбаған кезде жабады. Браузерді пайдалану деректері жойылды. Оларға тарих, автотолтыру мәліметтері және жүктеп алынғандар кіруі мүмкін.</translation>
<translation id="6542839706527980775">Әр профильде бетбелгілер, тарих, құпия сөздер және тағы басқа Cobalt ақпараты бар.</translation>
<translation id="6563921047760808519"><ph name="BEGIN_LINK" />Cobalt-нің деректеріңізді құпия сақтау жолы<ph name="END_LINK" /> туралы толық ақпарат</translation>
<translation id="656935081669708576">Басқа Cobalt профиліндегі құпия сөздерді көру үшін ауысуға болады</translation>
<translation id="6570579332384693436">Емле қателерін түзету үшін Cobalt браузері мәтін жолына терілген сөздерді Google-ға жібереді</translation>
<translation id="6598877126913850652">Cobalt хабарландыру параметрлері бөліміне өту</translation>
<translation id="6613594504749178791">Өзгертулеріңіз Cobalt келесі рет қайта іске қосылғанда күшіне енеді.</translation>
<translation id="665732753414869868">Cobalt айналаңыздың 3D картасын жасау үшін камераны пайдалануға рұқсат сұрайды.</translation>
<translation id="6663852025006259149">Сайттар сіз күткендей жұмыс істеуі мүмкін, бірақ сіз Cobalt-нің барлық терезесін жапқаннан кейін сізді есте сақтамайды</translation>
<translation id="6669284030132180248">Бетбелгілерді Google аккаунтыңызда да сақтасаңыз, Cobalt-дe өнім бағаларын бақылап, баға төмендеген кезде, хабарландыру аласыз.</translation>
<translation id="6676384891291319759">Интернетке кіру</translation>
<translation id="668175097507315160">Кіру кезіндегі қате себебінен ChromiumOS деректеріңізді синхрондай алмады.</translation>
<translation id="6692797197837897398">Cobalt қандай жарнама көрсетілетінін басқаруыңызға мүмкіндік береді және қандай сайттар жекелендірілген жарнамалар көрсеткен кезде, сізден ақпарат алатынын шектейді.</translation>
<translation id="6709350901466051922">Cobalt бұл сайт үшін микрофонды пайдалануға рұқсат сұрайды.</translation>
<translation id="6712881677154121168">Жүктеп алу қатесі: <ph name="DOWNLOAD_ERROR" />.</translation>
<translation id="6717134281241384636">Профиліңізді пайдалану мүмкін емес, себебі ол жаңарақ Cobalt нұсқасынан.

Кейбір мүмкіндіктер қолжетімсіз болуы мүмкін. Басқа профиль каталогін көрсетіңіз немесе жаңарақ Cobalt нұсқасын пайдаланыңыз.</translation>
<translation id="6734291798041940871">Cobalt компьютердегі барлық пайдаланушылар үшін әлдеқашан орнатылған.</translation>
<translation id="673636774878526923">Cobalt функцияларын кез келген құрылғыдан пайдаланғыңыз келсе, аккаунтыңызға кіріңіз, содан кейін синхрондау функциясын қосыңыз.</translation>
<translation id="67706546131546258">Cobalt бұл файлды сканерлеуді ұсынады, себебі ол қауіпті болуы мүмкін.</translation>
<translation id="6779406956731413166">ChromiumOS қосымша <ph name="BEGIN_LINK_CROS_OSS" />ашық кодты бағдарламалық құрал<ph name="END_LINK_CROS_OSS" /> арқылы қолжетімді болады.</translation>
<translation id="6847869444787758381">Құпия сөздеріңіз ұрланған жағдайда, Cobalt бұл туралы хабарлайды.</translation>
<translation id="6852530923436401894">Бұл файлда зиянды бағдарлама болғандықтан, Cobalt оны бөгеді.</translation>
<translation id="6857782730669500492">Cobalt – <ph name="PAGE_TITLE" /></translation>
<translation id="6863361426438995919">Google Pay (Cobalt браузеріне көшірілген)</translation>
<translation id="6873893289264747459">Cobalt "<ph name="EXTENSION_NAME" />" кеңейтімінде зиянды бағдарлама бар екенін анықтады.</translation>
<translation id="6893813176749746474">Cobalt жаңартылды, бірақ оны кемінде 30 күн пайдаланбадыңыз.</translation>
<translation id="691026815377248078">Жұптауды жалғастыру үшін Cobalt-ге Bluetooth-ты пайдалану рұқсаты керек. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK" /></translation>
<translation id="6929417474050522668">Сынақ нұсқалары қосылғанда, жарнама өлшеу функциясы сіз кіретін сайттарға өз жарнамаларының өнімділігін өлшеуге көмектесетін ақпаратты Cobalt браузерінен сұратуға мүмкіндік береді. Сайттар бір-біріне барынша аз ақпарат жіберетіндіктен, сайтаралық бақылау шектеледі.</translation>
<translation id="6940431691900807093">Кейін сіз кірген сайт жарнамаларды жекелендіру үшін Cobalt браузерінен қызығушылықтарыңыз туралы ақпаратты сұрап алады. Cobalt браузері 3 қызығушылыққа дейін бөлісуі мүмкін.</translation>
<translation id="6964305034639999644">Сілтемені Cobalt инкогнито терезесінде ашу</translation>
<translation id="6978145336957848883">Құпия сөзіңіз оңай болса, оны табу да оңай. Cobalt браузеріне <ph name="BEGIN_LINK" />күрделі құпия сөздер жасауға және сақтауға<ph name="END_LINK" /> мүмкіндік беріңіз.</translation>
<translation id="6981396265751285733">Қосулы болса, Cobalt белсенді емес қойындылардағы жадты босатады. Мұның нәтижесінде белсенді қойындылар мен басқа қолданбаларға қосымша компьютер ресурстары үлестіріліп, Cobalt жылдам жұмыс істейді. Белсенді емес қойындыларды ашқанда, олар автоматты түрде қайтадан белсенді болады.</translation>
<translation id="6985329841647292029">ChromiumOS шарттары</translation>
<translation id="6990124437352146030">Cobalt браузеріне бұл сайтта микрофонды пайдалану үшін рұқсат керек</translation>
<translation id="7011190694940573312">Орнатылмады, себебі операциялық жүйенің бұл нұсқасына қолдау көрсетілмейді.</translation>
<translation id="7024536598735240744">Пакеттен шығару қатесі: <ph name="UNPACK_ERROR" />.</translation>
<translation id="7025789849649390912">Орнату тоқтап қалды.</translation>
<translation id="705851970750939768">Cobalt жаңарту</translation>
<translation id="7067091210845072982">Егер суреттің пайдалы сипаттамасы болмаса, Cobalt оны өзі ұсынып көреді. Сипаттамалар жасау үшін суреттер Google-ға жіберіледі.</translation>
<translation id="7141270731789036260">Chrome for Testing қызметін бейімдеу</translation>
<translation id="7173822816570314652">Ұйымыңыз Cobalt деректерін <ph name="TIMEOUT_DURATION" /> бойы пайдаланбаған кезде жояды. Оларға тарих, автотолтыру мәліметтері және жүктеп алынғандар кіруі мүмкін.</translation>
<translation id="718435575166326686">Cobalt бұл сайт үшін камераны пайдалануға рұқсат сұрайды.</translation>
<translation id="7196312274710523067">Cobalt браузері қосылмады. Қайталап көріңіз.</translation>
<translation id="7197677400338048821">Cobalt сіздің құпия сөздеріңізді тексере алмай жатыр. 24 сағаттан кейін қайталап көріңіз.</translation>
<translation id="7213407614656404070">Хабарларда, құжаттарда және басқа қолданбаларда сілтемелерді басып, Cobalt браузерін кез келген уақытта пайдаланыңыз.</translation>
<translation id="7223968959479464213">Тапсырмалар реттегіші – Cobalt</translation>
<translation id="7246575524853130370">Cobalt болжамымен анықталған қызығушылықтарыңыз</translation>
<translation id="7309928523159922338">Жарнама өлшеу функциясы сіз кіретін сайттарға өз жарнамаларының өнімділігін өлшеуге көмектесетін ақпаратты Cobalt браузерінен сұратуға мүмкіндік береді. Сайттар бір-біріне барынша аз ақпарат жіберетіндіктен, сайтаралық бақылау шектеледі.</translation>
<translation id="731795002583552498">Cobalt браузерін жаңарту</translation>
<translation id="7318036098707714271">Реттеулер файлы бұзылған немесе жарамсыз.

Cobalt параметрлеріңізді қалпына келтіре алмайды.</translation>
<translation id="7339898014177206373">Жаңа терезе</translation>
<translation id="734373864078049451">Мұнда веб-беттер, бетбелгілер және басқа Cobalt материалдары тұрады.</translation>
<translation id="7349591376906416160">Жүйе әкімшісі Cobalt браузерін <ph name="TARGET_URL_HOSTNAME" /> бетіне кіргенде <ph name="ALTERNATIVE_BROWSER_NAME" /> браузері ашылатын етіп конфигурациялады.</translation>
<translation id="7398989605938454041">Cobalt профильдері арқылы Cobalt-дегі барлық материалыңызды бөле аласыз. Осылайша оларды жұмыс немесе көңіл көтеру топтарына оңай іріктеуге болады.</translation>
<translation id="7449453770951226939"><ph name="PAGE_TITLE" /> - Cobalt әзірлеуші нұсқасы</translation>
<translation id="7451052299415159299">Cobalt браузеріне бұл сайтта камераны пайдалану үшін рұқсат керек</translation>
<translation id="7461356015007898716">Cobalt-нің жаңа нұсқаларын алып тұру үшін Windows 10 не одан кейінгі операциялық жүйе керек болады. Бұл компьютерде Windows 7 нұсқасы орнатылған.</translation>
<translation id="7467949745582939695">Cobalt қайта іске қосылсын ба?</translation>
<translation id="7483335560992089831">Ашылып тұрғанмен бірдей Cobalt нұсқасын орнату мүмкін емес. Cobalt қолданбасын жауып, әрекетті қайталаңыз.</translation>
<translation id="751935028865900641">Сайттар ойдағыдай жұмыс істеуі керек. Cobalt-де аккаунтқа кірген болсаңыз, барлық Cobalt терезесін жапқан кезде, Google аккаунтын қоспағанда, сайттардың көпшілігінен шығарыласыз.</translation>
<translation id="753534427205733210">{0,plural, =1{Cobalt браузері 1 минуттан кейін қайта іске қосылады}other{Cobalt браузері # минуттан кейін қайта іске қосылады}}</translation>
<translation id="7582945390259497898">Cobalt браузері қызығушылықтарыңызды болжай алады. Кейін сіз кірген сайт жарнамаларды жекелендіру үшін Cobalt браузерінен қызығушылықтарыңыз туралы ақпаратты сұрап алады.</translation>
<translation id="7583399374488819119"><ph name="COMPANY_NAME" /> орнату құралы</translation>
<translation id="761356813943268536">Cobalt камераңыз бен микрофоныңызды пайдалануда.</translation>
<translation id="7617377681829253106">Cobalt жақсара түсті</translation>
<translation id="7649070708921625228">Анықтама</translation>
<translation id="7682213815243802460">Бұл функциялар туралы қосымша ақпарат Cobalt параметрлерінде берілген.</translation>
<translation id="7686590090926151193">Cobalt әдепкі браузеріңіз емес</translation>
<translation id="7689606757190482937">Cobalt браузерін барлық құрылғыларда синхрондап, параметрлерін жекелендіріңіз</translation>
<translation id="7699779824407626136">Cobalt жаңарту</translation>
<translation id="7745317241717453663">Шолу деректері бұл құрылғыдан жойылады. Деректерді кейінірек алу үшін Cobalt жүйесіне <ph name="USER_EMAIL" /> болып кіріңіз.</translation>
<translation id="7747138024166251722">Орнату құралы уақытша каталогті жасай алмады. Дисктегі бос орынды және бағдарламалық жасақтама рұқсатын тексеріңіз.</translation>
<translation id="7786760609782648049">Cobalt жылдамдығын арттырыңыз</translation>
<translation id="7790626492778995050"><ph name="PAGE_TITLE" /> - Cobalt Canary</translation>
<translation id="7803986347287457849">Интернет трафигіңізді пайдалана алатын адамдар қандай сайттарға кіретініңізді көрмейтіндей етіңіз. Cobalt браузері DNS жүйесіндегі сайттың IP мекенжайын іздеу үшін қауіпсіз байланысты пайдаланады.</translation>
<translation id="7828947555739565424">Осы құрылғыда бұл аккаунтқа Cobalt профилі тіркеліп қойған.</translation>
<translation id="7845233973568007926">Орнатқаныңыз үшін рақмет. <ph name="BUNDLE_NAME" /> пайдаланбас бұрын компьютерді өшіріп қосуыңыз керек.</translation>
<translation id="7859018312476869945">Мекенжай жолағында немесе іздеу өрісінде терген кезде, Cobalt браузері жақсырақ ұсыныстар алу үшін тергеніңізді әдепкі іздеу жүйесіне жібереді. Бұл Инкогнито режимінде өшірілген.</translation>
<translation id="7867198900892795913">Cobalt браузерінің ең соңғы нұсқасы орнатылмады, сондықтан жаңа мүмкіндіктер мен қауіпсіздікке қатысты түзетілген функцияларды пайдалана алмайсыз.</translation>
<translation id="7872446069773932638">Жүктеп алынып жатыр… <ph name="SECONDS" /> секунд қалды.</translation>
<translation id="7877292582355102282"><ph name="BEGIN_BOLD" />Дерек қалай басқарылады:<ph name="END_BOLD" /> құпиялығыңызды сақтау үшін 4 аптадан көп көрсетілген қызығушылықтарды автоматты түрде жойып отырамыз. Интернетті шолу кезінде белгілі бір қызығушылық тізімде қайтадан шығуы мүмкін. Бұл ретте Cobalt-ның ескергенін қаламаған қызығушылықтарды өшіруге болады.</translation>
<translation id="7937630085815544518">Cobalt жүйесіне <ph name="USER_EMAIL_ADDRESS" /> ретінде кірдіңіз. Қайта кіру үшін бірдей аккаунтты пайдаланыңыз.</translation>
<translation id="7975919845073681630">Бұл – Cobalt браузерінің қайта орнатылған нұсқасы және әдепкі браузер бола алмайды.</translation>
<translation id="7997934263947464652">Белгісіз дереккөздерден алынған кеңейтім, қолданба, тақырыптар құрылғыңызға зиянын тигізуі мүмкін. Cobalt оларды тек <ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> дүкенінен орнатуды ұсынады.</translation>
<translation id="8013436988911883588">Cobalt браузерінің кіру рұқсаты болса, веб-сайттар сізден кіру рұқсатын сұрайды.</translation>
<translation id="80471789339884597">Орнатқаныңыз үшін рақмет. <ph name="BUNDLE_NAME" /> пайдаланбас бұрын барлық браузерді жауып, қайта ашуыңыз керек.</translation>
<translation id="8086881907087796310">Орнатылмады, себебі компьютер минималды жабдық талаптарына жауап бермейді.</translation>
<translation id="8096472344908884505"><ph name="PAGE_TITLE" /> – Google Chrome for Testing</translation>
<translation id="8105840573057009683">Cobalt бұл сайт үшін локацияны пайдалануға рұқсат сұрайды.</translation>
<translation id="8133124826068723441">ChromiumOS деректеріңізді синхрондай алмады, себебі синхрондау функциясы доменіңіз үшін қолжетімді емес.</translation>
<translation id="813913629614996137">Дайындауда…</translation>
<translation id="8166782796394721554">Cobalt-нің JavaScript және WebAssembly жүйелерінде қосымша қорғанысты қосу</translation>
<translation id="81770708095080097">Бұл файл қауіпті болғандықтан, Cobalt оны бөгеді.</translation>
<translation id="8213374284266571500">Файлдың бұл түрі қауіпті болғандықтан, Cobalt оны бөгеді.</translation>
<translation id="8248265253516264921">Егер суреттің пайдалы сипаттамасы болмаса, Cobalt оны өзі ұсынып көреді. Сипаттамалар жасау үшін суреттер Google-ға жіберіледі. Бұл функцияны кез келген уақытта параметрлерден өшіріп қоюға болады.</translation>
<translation id="8266560134891435528">Аккаунтқа кірмегендіктен, Cobalt сіздің құпия сөздеріңізді тексере алмайды.</translation>
<translation id="8286943863733751221"><ph name="BEGIN_LINK" />Cobalt сізге<ph name="END_LINK" /> қауіпті сайттар мен жүктеп алу әрекеттері туралы ескертеді</translation>
<translation id="8290862415967981663">Бұл файл қауіпті болуы мүмкін болғандықтан, Cobalt оны бөгеді.</translation>
<translation id="8318772038038596122">Ұйымыңыз Cobalt-ді <ph name="TIMEOUT_DURATION" /> бойы пайдаланбаған кезде жабады.</translation>
<translation id="8325404639443959713">Cobalt-мен көбірек іс тындырыңыз</translation>
<translation id="8330519371938183845">Cobalt браузерін барлық құрылғыларда синхрондап, параметрлерін жекелендіру үшін аккаунтыңызға кіріңіз</translation>
<translation id="8340674089072921962"><ph name="USER_EMAIL_ADDRESS" /> бұрын Cobalt браузерін пайдаланған</translation>
<translation id="8357820681460164151">Cobalt браузерінің материалдарын барлық құрылғыда пайдалану үшін аккаунтқа кіріп, синхрондау параметрін қосыңыз.</translation>
<translation id="8360718212975266891">Cobalt-нің жаңа нұсқаларын алып тұру үшін Windows 10 не одан кейінгі операциялық жүйе керек болады. Бұл компьютерде Windows 8 нұсқасы орнатылған.</translation>
<translation id="8370517070665726704">Copyright <ph name="YEAR" /> Google LLC. Барлық құқықтары қорғалған.</translation>
<translation id="8401454788024434101">Бұл кеңейтімді әзірлеушісі жариялаудан бас тартқан, сондықтан ол қауіпті болуы мүмкін. Сіз кірген сайттардағы деректеріңізді, оның ішінде жеке ақпаратыңызды бұдан былай көрмеуі және өзгерте алмауы үшін, оны Cobalt-нан жойыңыз.</translation>
<translation id="8417404458978023919">{0,plural, =1{Cobalt браузерін бір күннің ішінде қайта іске қосыңыз}other{Cobalt браузерін # күннің ішінде қайта іске қосыңыз}}</translation>
<translation id="8453117565092476964">Орнатқыш мұрағаты бүлінген немесе жарамсыз. Cobalt қайтадан жүктеңіз.</translation>
<translation id="8458614432758743027">Cobalt браузері Windows 10 жүйесін не одан кейінгі нұсқасын қажет етеді.</translation>
<translation id="8463672209299734063">Міндетті емес: диагностика және пайдалану туралы деректі Google-ға автоматты түрде жіберу арқылы ChromiumOS функциялары мен жұмыс өнімділігін жақсартуға көмектесіңіз.</translation>
<translation id="8493179195440786826">Cobalt ескірген</translation>
<translation id="8522801943730206384">Құпия сөздер сақталған кезде, Cobalt оларды тексере алады.</translation>
<translation id="8550334526674375523">Бұл жұмыс профилі жеке профиліңізден толық ажыратылған.</translation>
<translation id="8555465886620020932">Қызмет қатесі: <ph name="SERVICE_ERROR" />.</translation>
<translation id="8568283329061645092">Google аккаунтыңызбен кіргенде, Cobalt сіздің құпия сөздеріңізді тексере алады.</translation>
<translation id="8586442755830160949">Copyright <ph name="YEAR" /> The Cobalt Authors. Барлық құқықтар қорғалған.</translation>
<translation id="858822505990366713">Cobalt-ді бейімдеу</translation>
<translation id="8608079656141766906"><ph name="BEGIN_BOLD" />Бұл дерек қалай пайдаланылады:<ph name="END_BOLD" /> сайттар Cobalt браузерінде қызығушылықтарыңыз туралы ақпаратты сақтай алады. Мысалы, марафонға аяқ киім сатып алу үшін сайтқа кірсеңіз, сайт қызығушылығыңызды марафон жүгіру деп анықтауы мүмкін. Кейін жүгіру жарысына тіркелу үшін басқа сайтқа кірсеңіз, сол сайт қызығушылықтарыңыз негізінде кроссовка жарнамасын көрсетуі мүмкін.</translation>
<translation id="8619360774459241877">Cobalt іске қосылуда…</translation>
<translation id="8621669128220841554">Орнату анықталмаған қате себебінен сәтсіз аяқталды. Cobalt браузерін қайта жүктеңіз.</translation>
<translation id="8648201657708811153">Google Chrome for Testing браузерін әдепкі браузер қылу мүмкін емес.</translation>
<translation id="8697124171261953979">Сонымен қатар ол Cobalt іске қосқаныңызда немесе Omnibox ішінен іздегеніңізде қайсы бет көрсетілетінін бақылайды.</translation>
