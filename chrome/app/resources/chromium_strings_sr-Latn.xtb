<ph name="USER_DATA_DIRECTORY" /></translation>
<translation id="3268051428841342958">V8 je Cobalt alatka za JavaScript i WebAssembly koja se koristi za poboljšanje performansi sajta</translation>
<translation id="3283186697780795848">Instalirana je verzija Cobalt-a <ph name="PRODUCT_VERSION" /></translation>
